{%- liquid
  assign section_id = section.id
-%}

<section
  id="tech-specs-strip-{{ section_id }}"
  class="tech-specs"
  data-section-id="{{ section_id }}"
>
  <div class="tech-specs__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="tech-specs__heading" data-reveal>{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="tech-specs__grid">
      {%- for block in section.blocks -%}
        <div class="tech-specs__item" data-reveal style="--i: {{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <div class="tech-specs__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'sensor' -%}
                <span class="tech-specs__stat">{{ block.settings.stat_value | default: '32' }}</span>
              {%- when 'battery' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="18" height="10" rx="2" ry="2"/><line x1="22" y1="11" x2="22" y2="13"/><path d="M6 10v4M10 10v4M14 10v4"/></svg>
                <span class="tech-specs__stat tech-specs__stat--inline">{{ block.settings.stat_value | default: '20h' }}</span>
              {%- when 'bluetooth' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="6.5 6.5 17.5 17.5 12 23 12 1 17.5 6.5 6.5 17.5"/></svg>
              {%- when 'washable' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="8" x2="21" y2="8"/><circle cx="12" cy="14" r="4"/></svg>
              {%- when 'finger' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 11V6a1.5 1.5 0 0 1 3 0v5"/><path d="M9 10V4a1.5 1.5 0 0 1 3 0v6"/><path d="M12 10V3a1.5 1.5 0 0 1 3 0v7"/><path d="M15 11V5a1.5 1.5 0 0 1 3 0v9a7 7 0 0 1-7 7h-1c-2.5 0-4-1-5.2-2.4L3 16.5a1.5 1.5 0 0 1 2.1-2.1L7 16"/></svg>
              {%- when 'eye' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/><line x1="4" y1="4" x2="20" y2="20"/></svg>
              {%- when 'gesture' -%}
                <svg viewBox="0 0 32 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12V7a1.3 1.3 0 0 1 2.6 0v5"/><path d="M6.6 11V5a1.3 1.3 0 0 1 2.6 0v6"/><path d="M9.2 11V4a1.3 1.3 0 0 1 2.6 0v7"/><path d="M11.8 12V6a1.3 1.3 0 0 1 2.6 0v8a6 6 0 0 1-6 6H7c-2 0-3.3-.7-4.4-1.9l-1.5-1.6"/><rect x="16" y="8" width="15" height="10" rx="2.5"/><circle cx="20" cy="13" r="0.8"/><circle cx="27" cy="13" r="0.8"/><circle cx="23.5" cy="11.5" r="0.6"/><circle cx="23.5" cy="14.5" r="0.6"/></svg>
              {%- when 'haptics' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12h3l3-9 4 18 3-9 3 5h4"/></svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
            {%- endcase -%}
          </div>

          {%- if block.settings.stat_value != blank and block.settings.icon != 'sensor' and block.settings.icon != 'battery' -%}
            <span class="tech-specs__stat tech-specs__stat--below">{{ block.settings.stat_value }}</span>
          {%- endif -%}

          <p class="tech-specs__label">{{ block.settings.label }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .tech-specs {
    background: #000;
    font-family: 'Montserrat', system-ui, sans-serif;
  }

  .tech-specs__inner {
    max-width: none;
    margin: 0;
    padding: 40px 80px;
    display: flex;
    flex-direction: column;
    gap: 32px;
    align-items: center;
  }

  @media (max-width: 1100px) {
    .tech-specs__inner {
      padding: 40px 32px;
    }
  }

  .tech-specs__heading {
    color: #fff;
    font-size: 22px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.3;
    text-align: center;
    margin: 0;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 600ms cubic-bezier(0.2, 0.8, 0.2, 1), transform 600ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .tech-specs__heading.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .tech-specs__grid {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(8, 1fr);
    gap: 12px;
    background: linear-gradient(180deg, #0f0817 0%, #08050f 100%);
    border: 1px solid rgba(168, 85, 247, 0.18);
    border-radius: 16px;
    padding: 32px 20px;
  }

  .tech-specs__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 500ms ease calc(var(--i, 0) * 60ms + 200ms),
      transform 500ms ease calc(var(--i, 0) * 60ms + 200ms);
  }

  .tech-specs__item.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .tech-specs__icon {
    color: #22d3ee;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    min-height: 32px;
  }

  .tech-specs__icon svg {
    width: 26px;
    height: 26px;
  }

  .tech-specs__icon svg[viewBox="0 0 32 24"] {
    width: 36px;
    height: 27px;
  }

  .tech-specs__stat {
    color: #22d3ee;
    font-size: 32px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.02em;
  }

  .tech-specs__stat--inline {
    font-size: 20px;
  }

  .tech-specs__stat--below {
    color: #22d3ee;
    font-size: 18px;
    font-weight: 700;
    line-height: 1;
  }

  .tech-specs__label {
    color: #d1d5db;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.35;
    margin: 0;
    max-width: 110px;
  }

  @media (prefers-reduced-motion: reduce) {
    .tech-specs__heading,
    .tech-specs__item {
      animation: none !important;
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }

  @media (max-width: 1100px) {
    .tech-specs__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 24px 16px;
    }
  }

  @media (max-width: 640px) {
    .tech-specs__inner {
      padding: 28px 16px;
    }
    .tech-specs__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding: 20px 12px;
      gap: 24px 12px;
    }
    .tech-specs__stat {
      font-size: 26px;
    }
    .tech-specs__label {
      font-size: 10px;
      max-width: 100%;
    }
  }

  @media (max-width: 380px) {
    .tech-specs__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px 8px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Tech Specs Strip",
  "tag": "section",
  "class": "section-tech-specs",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ADVANCED TECHNOLOGY. ULTIMATE IMMERSION."
    }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Spec",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "sensor",
          "options": [
            { "value": "sensor",     "label": "Sensor (large number)" },
            { "value": "battery",    "label": "Battery + hours" },
            { "value": "bluetooth",  "label": "Bluetooth" },
            { "value": "washable",   "label": "Machine washable" },
            { "value": "finger",     "label": "Finger splay" },
            { "value": "eye",        "label": "No camera occlusion" },
            { "value": "gesture",    "label": "Gesture mapping" },
            { "value": "haptics",    "label": "Haptics (waveform)" }
          ]
        },
        {
          "type": "text",
          "id": "stat_value",
          "label": "Stat value (optional)",
          "info": "e.g. \"32\", \"20h\". Only used with Sensor and Battery icons."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Stretch Sensors"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Tech Specs Strip",
      "blocks": [
        { "type": "spec", "settings": { "icon": "sensor",    "stat_value": "32",  "label": "Stretch Sensors" } },
        { "type": "spec", "settings": { "icon": "battery",   "stat_value": "20h", "label": "Battery Life" } },
        { "type": "spec", "settings": { "icon": "bluetooth", "label": "Bluetooth Wireless" } },
        { "type": "spec", "settings": { "icon": "washable",  "label": "Machine Washable" } },
        { "type": "spec", "settings": { "icon": "finger",    "label": "Individual Finger Splay" } },
        { "type": "spec", "settings": { "icon": "eye",       "label": "No Camera Occlusion" } },
        { "type": "spec", "settings": { "icon": "gesture",   "label": "Gesture Mapping" } },
        { "type": "spec", "settings": { "icon": "haptics",   "label": "Optional Haptics" } }
      ]
    }
  ]
}
{% endschema %}
