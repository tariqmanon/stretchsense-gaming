{%- liquid
  assign section_id = section.id
-%}
<section
  id="feels-different-{{ section_id }}"
  class="feels-different"
  data-section-id="{{ section_id }}"
>
  <div class="feels-different__inner">

    <div class="feels-different__col feels-different__col--intro" data-reveal>
      {%- if section.settings.eyebrow != blank -%}
        <p class="feels-different__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="feels-different__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <div class="feels-different__body">{{ section.settings.body }}</div>
      {%- endif -%}
    </div>

    <div class="feels-different__col feels-different__col--compare" data-reveal>
      {%- liquid
        assign left_split = section.settings.compare_left_items | newline_to_br | split: '<br />'
        assign right_split = section.settings.compare_right_items | newline_to_br | split: '<br />'

        capture left_joined
          for item in left_split
            assign trimmed = item | strip
            if trimmed != ''
              echo trimmed
              echo '|||'
            endif
          endfor
        endcapture
        assign left_items = left_joined | split: '|||'
        assign left_count = left_items | size

        capture right_joined
          for item in right_split
            assign trimmed = item | strip
            if trimmed != ''
              echo trimmed
              echo '|||'
            endif
          endfor
        endcapture
        assign right_items = right_joined | split: '|||'
        assign right_count = right_items | size

        assign max_count = left_count
        if right_count > left_count
          assign max_count = right_count
        endif
        assign middle_row = max_count | minus: 1 | divided_by: 2
      -%}

      <div class="feels-different__compare">
        <div class="feels-different__compare-grid">
          <h3 class="feels-different__compare-heading feels-different__compare-heading--muted">
            {{ section.settings.compare_left_heading | default: 'CONTROLLERS' }}
          </h3>
          <div class="feels-different__compare-vs-header" aria-hidden="true"></div>
          <h3 class="feels-different__compare-heading">
            {{ section.settings.compare_right_heading | default: 'STRETCHSENSE GLOVES' }}
          </h3>

          {%- for i in (0..99) -%}
            {%- if i >= max_count -%}{%- break -%}{%- endif -%}
            {%- assign left_text = left_items[i] -%}
            {%- assign right_text = right_items[i] -%}

            <div class="feels-different__compare-cell feels-different__compare-cell--left">
              {%- if left_text != blank -%}
                <span class="feels-different__check feels-different__check--off" aria-hidden="true"></span>
                <span>{{ left_text }}</span>
              {%- endif -%}
            </div>

            <div class="feels-different__compare-cell feels-different__compare-cell--vs" aria-hidden="true">
              {%- if i == middle_row -%}
                <span class="feels-different__compare-vs-badge">VS</span>
              {%- endif -%}
            </div>

            <div class="feels-different__compare-cell feels-different__compare-cell--right">
              {%- if right_text != blank -%}
                <span class="feels-different__check feels-different__check--on" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                <span>{{ right_text }}</span>
              {%- endif -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>

    <div
      class="feels-different__col feels-different__col--personas{% if section.settings.personas_bg_image != blank %} feels-different__col--personas-has-bg{% endif %}"
      data-reveal
      {%- if section.settings.personas_bg_image != blank %}
        style="--personas-bg-image: url('{{ section.settings.personas_bg_image | image_url: width: 1200 }}'); --personas-overlay-opacity: {{ section.settings.personas_overlay_opacity | default: 55 | divided_by: 100.0 }};"
      {%- endif -%}
    >
      {%- if section.settings.personas_eyebrow != blank -%}
        <p class="feels-different__eyebrow feels-different__eyebrow--personas">{{ section.settings.personas_eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.personas_heading != blank -%}
        <h3 class="feels-different__personas-heading">{{ section.settings.personas_heading }}</h3>
      {%- endif -%}
      {%- if section.settings.personas_body != blank -%}
        <p class="feels-different__personas-body">{{ section.settings.personas_body }}</p>
      {%- endif -%}

      <div class="feels-different__personas-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'persona' -%}
            <div class="feels-different__persona" {{ block.shopify_attributes }}>
              <div class="feels-different__persona-icon" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'vtuber' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 3 7l9 5 9-5-9-5z"/><path d="M3 12l9 5 9-5"/><path d="M3 17l9 5 9-5"/></svg>
                  {%- when 'streamer' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="6" width="14" height="12" rx="2" ry="2"/><polygon points="22 8 16 12 22 16 22 8"/></svg>
                  {%- when 'creator' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 1 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                  {%- when 'animator' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
                {%- endcase -%}
              </div>
              <p class="feels-different__persona-label">{{ block.settings.label }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

{% stylesheet %}
  .feels-different {
    background: #000;
    font-family: 'Montserrat', system-ui, sans-serif;
  }

  .feels-different__inner {
    max-width: none;
    margin: 0;
    padding: 56px 80px;
    display: grid;
    grid-template-columns: 1fr 1.35fr 1.05fr;
    gap: 32px;
    align-items: stretch;
  }

  @media (max-width: 1100px) {
    .feels-different__inner {
      padding: 56px 32px;
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  /* --- Intro column --- */
  .feels-different__col {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 600ms cubic-bezier(0.2, 0.8, 0.2, 1), transform 600ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .feels-different__col.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .feels-different__eyebrow {
    color: #d1d5db;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 10px;
  }

  .feels-different__eyebrow--personas {
    text-align: center;
  }

  .feels-different__heading {
    color: #fff;
    font-size: 30px;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 18px;
    background: linear-gradient(90deg, #ffffff 40%, #c084fc 85%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .feels-different__body {
    color: #a4a6ab;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.6;
  }

  .feels-different__body p {
    margin: 0 0 12px;
  }

  .feels-different__body p:last-child {
    margin-bottom: 0;
  }

  /* --- Compare column --- */
  .feels-different__compare {
    background: linear-gradient(180deg, #0f0817 0%, #08050f 100%);
    border: 1px solid rgba(168, 85, 247, 0.18);
    border-radius: 16px;
    padding: 28px 14px;
    height: 100%;
    display: flex;
    justify-content: center;
  }

  .feels-different__compare-grid {
    display: grid;
    grid-template-columns: max-content auto max-content;
    column-gap: 60px;
    row-gap: 12px;
    align-items: center;
    justify-items: start;
  }

  .feels-different__compare-heading {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 4px;
    text-align: left;
    padding-left: 0;
    color: #c084fc;
    justify-self: start;
    white-space: nowrap;
  }

  .feels-different__compare-heading--muted {
    color: #71717a;
  }

  .feels-different__compare-vs-header {
    /* empty spacer cell in header row to keep 3-column grid aligned */
  }

  .feels-different__compare-cell {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    line-height: 1.4;
    min-height: 22px;
    white-space: nowrap;
  }

  .feels-different__compare-cell--left {
    color: #71717a;
  }

  .feels-different__compare-cell--right {
    color: #d1d5db;
  }

  .feels-different__compare-cell--vs {
    display: flex;
    align-items: center;
    justify-content: center;
    justify-self: center;
  }

  .feels-different__compare-vs-badge {
    font-size: 11px;
    font-weight: 700;
    color: #71717a;
    letter-spacing: 0.14em;
    background: rgba(168, 85, 247, 0.14);
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 50%;
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .feels-different__check {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .feels-different__check--off {
    border: 1.5px solid #52525b;
    background: transparent;
  }

  .feels-different__check--on {
    background: linear-gradient(135deg, #a855f7 0%, #ec4899 100%);
    color: #fff;
  }

  .feels-different__check--on svg {
    width: 12px;
    height: 12px;
  }

  /* --- Personas column --- */
  .feels-different__col--personas {
    position: relative;
    background: linear-gradient(180deg, #0f0817 0%, #08050f 100%);
    border: 1px solid rgba(168, 85, 247, 0.18);
    border-radius: 16px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    overflow: hidden;
    z-index: 0;
  }

  .feels-different__col--personas-has-bg {
    background-image: var(--personas-bg-image);
    background-size: cover;
    background-position: center 30%;
    background-repeat: no-repeat;
  }

  .feels-different__col--personas-has-bg::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(8, 5, 15, calc(var(--personas-overlay-opacity, 0.55) * 0.6)) 0%,
      rgba(8, 5, 15, var(--personas-overlay-opacity, 0.55)) 55%,
      rgba(8, 5, 15, 0.92) 100%
    );
    z-index: 0;
    pointer-events: none;
  }

  .feels-different__col--personas > * {
    position: relative;
    z-index: 1;
  }

  .feels-different__personas-heading {
    color: #fff;
    font-size: 22px;
    font-weight: 800;
    line-height: 1.2;
    margin: 0;
    background: linear-gradient(90deg, #ffffff 40%, #ec4899 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .feels-different__personas-body {
    color: #a4a6ab;
    font-size: 13px;
    line-height: 1.55;
    margin: 0 0 10px;
  }

  .feels-different__personas-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 8px;
    width: 100%;
    max-width: 100%;
    overflow: hidden;
  }

  .feels-different__persona {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 12px 2px;
    border-radius: 10px;
    transition: background 200ms ease;
    min-width: 0;
    text-align: center;
  }

  .feels-different__persona:hover {
    background: rgba(168, 85, 247, 0.08);
  }

  .feels-different__persona-icon {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #c084fc;
  }

  .feels-different__persona-icon svg {
    width: 22px;
    height: 22px;
  }

  .feels-different__persona-label {
    color: #d1d5db;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    word-break: break-word;
    hyphens: auto;
    max-width: 100%;
    text-transform: uppercase;
    line-height: 1.3;
    margin: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .feels-different__col {
      animation: none !important;
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }

  @media (max-width: 560px) {
    .feels-different__inner {
      padding: 40px 16px;
    }

    .feels-different__compare {
      grid-template-columns: 1fr;
      padding: 20px 16px;
    }

    .feels-different__compare-divider {
      padding-top: 0;
    }

    .feels-different__personas-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Why + Personas",
  "tag": "section",
  "class": "section-feels-different",
  "max_blocks": 6,
  "settings": [
    { "type": "header", "content": "Left column — Intro" },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "WHY STRETCHSENSE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FEELS DIFFERENT"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Controllers have buttons. StretchSense gives you freedom.</p><p>Every finger. Every gesture. Every interaction. No limitations. Just you, in VR.</p>"
    },

    { "type": "header", "content": "Middle column — Comparison" },
    {
      "type": "text",
      "id": "compare_left_heading",
      "label": "Left heading",
      "default": "CONTROLLERS"
    },
    {
      "type": "textarea",
      "id": "compare_left_items",
      "label": "Left items (one per line)",
      "default": "Button Presses\nTrigger Pull\nLimited Gestures\nAvatar Hands\nFixed Input"
    },
    {
      "type": "text",
      "id": "compare_right_heading",
      "label": "Right heading",
      "default": "STRETCHSENSE GLOVES"
    },
    {
      "type": "textarea",
      "id": "compare_right_items",
      "label": "Right items (one per line)",
      "default": "Natural Grab & Release\nReal Finger Movement\nFull Hand Expression\nYour Hands in VR\nNatural Interaction"
    },

    { "type": "header", "content": "Right column — Personas" },
    {
      "type": "image_picker",
      "id": "personas_bg_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "personas_overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 55
    },
    {
      "type": "text",
      "id": "personas_eyebrow",
      "label": "Personas eyebrow",
      "default": "PERFECT FOR"
    },
    {
      "type": "text",
      "id": "personas_heading",
      "label": "Personas heading",
      "default": "CREATORS & STREAMERS"
    },
    {
      "type": "textarea",
      "id": "personas_body",
      "label": "Personas body",
      "default": "Capture natural hand movements for VTubing, content creation, animation, live streaming and more."
    }
  ],
  "blocks": [
    {
      "type": "persona",
      "name": "Persona",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "vtuber",
          "options": [
            { "value": "vtuber", "label": "VTuber" },
            { "value": "streamer", "label": "Streamer" },
            { "value": "creator", "label": "Content creator" },
            { "value": "animator", "label": "Animator" }
          ]
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "VTUBERS"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why + Personas",
      "blocks": [
        { "type": "persona", "settings": { "icon": "vtuber", "label": "VTUBERS" } },
        { "type": "persona", "settings": { "icon": "streamer", "label": "STREAMERS" } },
        { "type": "persona", "settings": { "icon": "creator", "label": "CONTENT CREATORS" } },
        { "type": "persona", "settings": { "icon": "animator", "label": "ANIMATORS" } }
      ]
    }
  ]
}
{% endschema %}
