{%- liquid
  assign section_id = section.id
-%}

<section
  id="features-bar-{{ section_id }}"
  class="features-bar"
  data-section-id="{{ section_id }}"
>
  <div class="features-bar__inner">
    <div class="features-bar__card">
      {%- for block in section.blocks -%}
        <div class="features-bar__item" {{ block.shopify_attributes }}>
          <div class="features-bar__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'precision' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="#ff6b1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                  <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                </svg>
              {%- when 'immersion' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="#ff6b1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                  <circle cx="12" cy="12" r="3"/>
                </svg>
              {%- when 'compatibility' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="#ff6b1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M19.439 7.85c-.049.322.059.648.289.878l1.568 1.568c.47.47.706 1.087.706 1.704s-.235 1.233-.706 1.704l-1.611 1.611a.98.98 0 0 1-.837.276c-.47-.07-.802-.48-.968-.925a2.5 2.5 0 1 0-3.214 3.214c.446.166.855.497.925.968a.98.98 0 0 1-.276.837l-1.61 1.61a2.404 2.404 0 0 1-1.705.707 2.402 2.402 0 0 1-1.704-.706l-1.568-1.568a1.026 1.026 0 0 0-.877-.29c-.493.074-.84.504-1.02.968a2.5 2.5 0 1 1-3.237-3.237c.464-.18.894-.527.967-1.02a1.026 1.026 0 0 0-.289-.877l-1.568-1.568A2.402 2.402 0 0 1 2 12c0-.617.236-1.234.706-1.704L4.318 8.684c.23-.23.556-.338.877-.29.493.074.84.504 1.02.968a2.5 2.5 0 1 0 3.237-3.237c-.464-.18-.894-.527-.967-1.02a1.026 1.026 0 0 1 .289-.877l1.568-1.568a2.402 2.402 0 0 1 1.704-.706c.617 0 1.234.235 1.704.706l1.611 1.611c.23.23.338.556.29.877-.074.493-.504.84-.968 1.02a2.5 2.5 0 1 0 3.237 3.237c.18-.464.527-.894 1.02-.967z"/>
                </svg>
              {%- when 'gamers' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="#ff6b1a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="6" y1="11" x2="10" y2="11"/>
                  <line x1="8" y1="9" x2="8" y2="13"/>
                  <line x1="15" y1="12" x2="15.01" y2="12"/>
                  <line x1="18" y1="10" x2="18.01" y2="10"/>
                  <path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/>
                </svg>
            {%- endcase -%}
          </div>
          <p class="features-bar__title">{{ block.settings.title }}</p>
          <p class="features-bar__description">{{ block.settings.description }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .features-bar {
    background: #000;
    font-family: 'Montserrat', system-ui, sans-serif;
  }

  .features-bar__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px 24px;
  }

  .features-bar__card {
    background: #04091a;
    border: 1px solid rgba(0, 209, 219, 0.2);
    border-radius: 16px;
    padding: 28px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .features-bar__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    text-align: center;
  }

  .features-bar__icon {
    width: 56px;
    height: 56px;
    border-radius: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .features-bar__icon svg {
    width: 24px;
    height: 24px;
  }

  .features-bar__title {
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.43;
    margin: 0;
  }

  .features-bar__description {
    color: #818286;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.33;
    margin: 0;
    max-width: 168px;
  }

  @media (max-width: 768px) {
    .features-bar__card {
      grid-template-columns: repeat(2, 1fr);
      padding: 24px 16px;
      gap: 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Features Bar",
  "tag": "section",
  "class": "section-features-bar",
  "max_blocks": 6,
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "precision",
          "options": [
            { "value": "precision", "label": "Precision (chain)" },
            { "value": "immersion", "label": "Immersion (eye)" },
            { "value": "compatibility", "label": "Compatibility (puzzle)" },
            { "value": "gamers", "label": "Gamers (controller)" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Precision"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "360° tracking for total hand awareness."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Bar",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "precision",
            "title": "Precision",
            "description": "360° tracking for total hand awareness."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "immersion",
            "title": "Immersion",
            "description": "Feel every action in vibrant detail."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "compatibility",
            "title": "Compatibility",
            "description": "Works with leading VR headsets and games."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "gamers",
            "title": "Built for Gamers",
            "description": "Lightweight, breathable, and durable."
          }
        }
      ]
    }
  ]
}
{% endschema %}
