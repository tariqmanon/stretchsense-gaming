{%- liquid
  assign section_id = section.id
-%}

<section
  id="features-bar-{{ section_id }}"
  class="features-bar"
  data-section-id="{{ section_id }}"
>
  <div class="features-bar__inner">
    <div class="features-bar__grid">
      {%- for block in section.blocks -%}
        <article class="features-bar__card" data-reveal style="--i: {{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <div class="features-bar__media">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 720 }}"
                srcset="{{ block.settings.image | image_url: width: 360 }} 360w, {{ block.settings.image | image_url: width: 720 }} 720w"
                sizes="(max-width: 900px) 100vw, 25vw"
                alt="{{ block.settings.title | escape }}"
                width="360"
                height="220"
                loading="lazy"
              >
            {%- else -%}
              <div class="features-bar__media-placeholder" aria-hidden="true">
                <span class="features-bar__media-glow"></span>
              </div>
            {%- endif -%}
          </div>

          <div class="features-bar__body">
            <div class="features-bar__title-row">
              <span class="features-bar__icon" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'hand' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"/><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/></svg>
                  {%- when 'chat' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                  {%- when 'controller' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="11" x2="10" y2="11"/><line x1="8" y1="9" x2="8" y2="13"/><line x1="15" y1="12" x2="15.01" y2="12"/><line x1="18" y1="10" x2="18.01" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.545-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/></svg>
                  {%- when 'feather' -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/><line x1="17.5" y1="15" x2="9" y2="15"/></svg>
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/></svg>
                {%- endcase -%}
              </span>
              <h3 class="features-bar__title">{{ block.settings.title }}</h3>
            </div>
            <p class="features-bar__description">{{ block.settings.description }}</p>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .features-bar {
    background: #000;
    font-family: 'Montserrat', system-ui, sans-serif;
  }

  .features-bar__inner {
    max-width: none;
    margin: 0;
    padding: 24px 80px 40px;
  }

  @media (max-width: 1100px) {
    .features-bar__inner {
      padding: 24px 32px 40px;
    }
  }

  .features-bar__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .features-bar__card {
    background: linear-gradient(180deg, #0f0817 0%, #08050f 100%);
    border: 1px solid rgba(168, 85, 247, 0.15);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 600ms cubic-bezier(0.2, 0.8, 0.2, 1) calc(var(--i, 0) * 80ms + 100ms),
      transform 600ms cubic-bezier(0.2, 0.8, 0.2, 1) calc(var(--i, 0) * 80ms + 100ms),
      border-color 250ms ease,
      box-shadow 250ms ease;
  }

  .features-bar__card.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .features-bar__card:hover {
    border-color: rgba(168, 85, 247, 0.45);
    box-shadow: 0 12px 32px rgba(168, 85, 247, 0.18);
  }

  .features-bar__media {
    aspect-ratio: 16 / 10;
    background: #0a0611;
    overflow: hidden;
    position: relative;
  }

  .features-bar__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 500ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .features-bar__card:hover .features-bar__media img {
    transform: scale(1.04);
  }

  .features-bar__media-placeholder {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(circle at 30% 30%, rgba(168, 85, 247, 0.28), transparent 50%),
      radial-gradient(circle at 70% 70%, rgba(236, 72, 153, 0.22), transparent 50%),
      linear-gradient(135deg, #1a0d2e 0%, #0a0611 100%);
    position: relative;
    overflow: hidden;
  }

  .features-bar__media-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(192, 132, 252, 0.35), transparent 60%);
    animation: features-glow 5s ease-in-out infinite;
  }

  .features-bar__body {
    padding: 20px 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .features-bar__title-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .features-bar__icon {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: rgba(168, 85, 247, 0.15);
    border: 1px solid rgba(168, 85, 247, 0.35);
    color: #c084fc;
    flex-shrink: 0;
    transition: transform 250ms ease, background 250ms ease;
  }

  .features-bar__card:hover .features-bar__icon {
    background: rgba(168, 85, 247, 0.25);
    transform: scale(1.06);
  }

  .features-bar__icon svg {
    width: 18px;
    height: 18px;
  }

  .features-bar__title {
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0;
  }

  .features-bar__description {
    color: #a4a6ab;
    font-size: 13px;
    font-weight: 400;
    line-height: 1.55;
    margin: 0;
  }

  @keyframes features-glow {
    0%, 100% { opacity: 0.7; transform: scale(1); }
    50%      { opacity: 1;   transform: scale(1.08); }
  }

  @media (prefers-reduced-motion: reduce) {
    .features-bar__card,
    .features-bar__media img,
    .features-bar__icon,
    .features-bar__media-glow {
      animation: none !important;
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }

  @media (max-width: 900px) {
    .features-bar__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .features-bar__grid {
      grid-template-columns: 1fr;
    }

    .features-bar__inner {
      padding: 20px 16px 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Features Bar",
  "tag": "section",
  "class": "section-features-bar",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "16:10 aspect works best. Falls back to a purple gradient placeholder if empty."
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "hand",
          "options": [
            { "value": "hand", "label": "Hand (finger tracking)" },
            { "value": "chat", "label": "Chat (social)" },
            { "value": "controller", "label": "Controller (gameplay)" },
            { "value": "feather", "label": "Feather (comfort)" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "NATURAL FINGER TRACKING"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "32 stretch sensors capture every finger movement with incredible precision and accuracy."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Bar",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "hand",
            "title": "NATURAL FINGER TRACKING",
            "description": "32 stretch sensors capture every finger movement with incredible precision and accuracy."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "chat",
            "title": "EXPRESSIVE SOCIAL VR",
            "description": "Make gestures, wave, point, grab and express yourself naturally in VRChat, Rec Room, Neos and more."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "controller",
            "title": "CONTROLLER-FREE GAMEPLAY",
            "description": "Interact with the world using your real hands. More immersion. More freedom. More ways to play."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "feather",
            "title": "ALL-DAY COMFORT",
            "description": "Lightweight, breathable and machine washable for long VR sessions that go the distance."
          }
        }
      ]
    }
  ]
}
{% endschema %}
