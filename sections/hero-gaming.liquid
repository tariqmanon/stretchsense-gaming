{%- liquid
  assign section_id = section.id
-%}

<section
  id="hero-gaming-{{ section_id }}"
  class="hero-gaming"
  data-section-id="{{ section_id }}"
>
  <div class="hero-gaming__inner">
    <div class="hero-gaming__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hero-gaming__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.headline != blank -%}
        <h1 class="hero-gaming__headline">{{ section.settings.headline }}</h1>
      {%- endif -%}

      {%- if section.settings.subheadline != blank -%}
        <div class="hero-gaming__subheadline">{{ section.settings.subheadline }}</div>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="hero-gaming__description">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.settings.price != blank -%}
        <p class="hero-gaming__price">{{ section.settings.price }}</p>
      {%- endif -%}

      <div class="hero-gaming__ctas">
        {%- if section.settings.primary_label != blank -%}
          <a
            class="hero-gaming__cta hero-gaming__cta--primary"
            href="{{ section.settings.primary_link | default: '#' }}"
          >
            <span>{{ section.settings.primary_label }}</span>
            <span aria-hidden="true">&rarr;</span>
          </a>
        {%- endif -%}

        {%- if section.settings.secondary_label != blank -%}
          <a
            class="hero-gaming__cta hero-gaming__cta--secondary"
            href="{{ section.settings.secondary_link | default: '#' }}"
          >
            {{ section.settings.secondary_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="hero-gaming__visual">
      {%- if section.settings.hero_image != blank -%}
        <img
          src="{{ section.settings.hero_image | image_url: width: 1100 }}"
          srcset="{{ section.settings.hero_image | image_url: width: 600 }} 600w, {{ section.settings.hero_image | image_url: width: 900 }} 900w, {{ section.settings.hero_image | image_url: width: 1100 }} 1100w"
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="{{ section.settings.hero_image.alt | default: section.settings.headline | escape }}"
          width="{{ section.settings.hero_image.width }}"
          height="{{ section.settings.hero_image.height }}"
          loading="eager"
          fetchpriority="high"
        >
      {%- else -%}
        <img
          src="{{ 'hero-gaming-gloves.png' | asset_url }}"
          alt="{{ section.settings.headline | escape }}"
          width="1088"
          height="1088"
          loading="eager"
          fetchpriority="high"
        >
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .hero-gaming {
    background: #000;
    color: #fff;
    font-family: 'Montserrat', system-ui, sans-serif;
    overflow: hidden;
  }

  .hero-gaming__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 64px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: 32px;
    align-items: center;
    min-height: 520px;
  }

  .hero-gaming__copy {
    display: flex;
    flex-direction: column;
    gap: 18px;
    max-width: 420px;
  }

  .hero-gaming__eyebrow {
    color: #ff6b1a;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.33;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0;
  }

  .hero-gaming__headline {
    color: #ff6b1a;
    font-size: 64px;
    font-weight: 700;
    line-height: 1.25;
    margin: 0;
  }

  .hero-gaming__subheadline {
    color: #fff;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.43;
  }

  .hero-gaming__subheadline p {
    margin: 0;
  }

  .hero-gaming__description {
    color: #a4a6ab;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.43;
    margin: 0;
    max-width: 334px;
  }

  .hero-gaming__price {
    color: #fff;
    font-size: 40px;
    font-weight: 700;
    line-height: 1.4;
    margin: 0;
  }

  .hero-gaming__ctas {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero-gaming__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 24px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.43;
    text-decoration: none;
    transition: opacity 150ms ease, transform 150ms ease;
  }

  .hero-gaming__cta--primary {
    background: #ff6b1a;
    color: #fff;
  }

  .hero-gaming__cta--primary:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .hero-gaming__cta--secondary {
    border: 1px solid rgba(255, 255, 255, 0.4);
    color: #fff;
  }

  .hero-gaming__cta--secondary:hover {
    background: rgba(255, 255, 255, 0.08);
  }

  .hero-gaming__visual {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 600px;
    margin-left: auto;
  }

  .hero-gaming__visual img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  @media (max-width: 900px) {
    .hero-gaming__inner {
      grid-template-columns: 1fr;
      padding: 32px 24px;
      gap: 24px;
      text-align: center;
    }

    .hero-gaming__copy {
      max-width: none;
      align-items: center;
    }

    .hero-gaming__description {
      max-width: none;
    }

    .hero-gaming__headline {
      font-size: 48px;
    }

    .hero-gaming__subheadline {
      font-size: 22px;
    }

    .hero-gaming__price {
      font-size: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Gaming",
  "tag": "section",
  "class": "section-hero-gaming",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "STRETCHSENSE"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "GAMING"
    },
    {
      "type": "richtext",
      "id": "subheadline",
      "label": "Sub-headline",
      "default": "<p>Feel Every Move.</p><p>Own Every Game.</p>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Built for ultimate VR gaming gloves for immersion, precision, and performance."
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "$495"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image (gloves)",
      "info": "Falls back to bundled default if empty"
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Buy Now"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Gaming"
    }
  ]
}
{% endschema %}
