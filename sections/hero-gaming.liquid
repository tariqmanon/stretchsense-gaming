{%- liquid
  assign section_id = section.id
-%}

<section
  id="hero-gaming-{{ section_id }}"
  class="hero-gaming"
  data-section-id="{{ section_id }}"
>
  <div class="hero-gaming__glow" aria-hidden="true"></div>

  <div class="hero-gaming__inner">
    <div class="hero-gaming__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hero-gaming__eyebrow" style="--delay: 50ms">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.headline != blank -%}
        <h1 class="hero-gaming__headline" style="--delay: 150ms">{{ section.settings.headline }}</h1>
      {%- endif -%}

      {%- if section.settings.subheadline != blank -%}
        <div class="hero-gaming__subheadline" style="--delay: 300ms">{{ section.settings.subheadline }}</div>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="hero-gaming__description" style="--delay: 400ms">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.settings.price != blank -%}
        <p class="hero-gaming__price" style="--delay: 500ms">{{ section.settings.price }}</p>
      {%- endif -%}

      <div class="hero-gaming__ctas" style="--delay: 600ms">
        {%- if section.settings.primary_label != blank -%}
          <a
            class="hero-gaming__cta hero-gaming__cta--primary"
            href="{{ section.settings.primary_link | default: '#' }}"
          >
            <span>{{ section.settings.primary_label }}</span>
            <span class="hero-gaming__cta-arrow" aria-hidden="true">&rarr;</span>
          </a>
        {%- endif -%}

        {%- if section.settings.secondary_label != blank -%}
          <a
            class="hero-gaming__cta hero-gaming__cta--secondary"
            href="{{ section.settings.secondary_link | default: '#' }}"
          >
            {{ section.settings.secondary_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="hero-gaming__visual">
      {%- if section.settings.hero_image != blank -%}
        <img
          src="{{ section.settings.hero_image | image_url: width: 1100 }}"
          srcset="{{ section.settings.hero_image | image_url: width: 600 }} 600w, {{ section.settings.hero_image | image_url: width: 900 }} 900w, {{ section.settings.hero_image | image_url: width: 1100 }} 1100w"
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="{{ section.settings.hero_image.alt | default: section.settings.headline | escape }}"
          width="{{ section.settings.hero_image.width }}"
          height="{{ section.settings.hero_image.height }}"
          loading="eager"
          fetchpriority="high"
        >
      {%- else -%}
        <img
          src="{{ 'hero-gaming-gloves.png' | asset_url }}"
          alt="{{ section.settings.headline | escape }}"
          width="1088"
          height="1088"
          loading="eager"
          fetchpriority="high"
        >
      {%- endif -%}
    </div>
  </div>
</section>

<script src="{{ 'gaming-animations.js' | asset_url }}" defer></script>

{% stylesheet %}
  .hero-gaming {
    background: #000;
    color: #fff;
    font-family: 'Montserrat', system-ui, sans-serif;
    overflow: hidden;
    position: relative;
  }

  .hero-gaming__glow {
    position: absolute;
    top: 50%;
    right: -10%;
    width: 70%;
    height: 90%;
    transform: translateY(-50%);
    background: radial-gradient(circle, rgba(168, 85, 247, 0.28) 0%, rgba(236, 72, 153, 0.12) 40%, transparent 70%);
    pointer-events: none;
    animation: hero-pulse 6s ease-in-out infinite;
  }

  .hero-gaming__inner {
    max-width: none;
    margin: 0;
    padding: 32px 80px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.4fr);
    gap: 32px;
    align-items: center;
    min-height: 520px;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 1100px) {
    .hero-gaming__inner {
      padding: 32px 32px;
    }
  }

  .hero-gaming__copy {
    display: flex;
    flex-direction: column;
    gap: 18px;
    max-width: 420px;
  }

  @media (min-width: 992px) {
    .hero-gaming__copy {
      padding-left: 82px;
    }
  }

  .hero-gaming__copy > * {
    opacity: 0;
    transform: translateY(16px);
    animation: hero-rise 800ms cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  .hero-gaming__eyebrow {
    color: #c084fc;
    font-size: 12px;
    font-weight: 600;
    line-height: 1.33;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0;
  }

  .hero-gaming__headline {
    font-size: 64px;
    font-weight: 800;
    line-height: 1.05;
    margin: 0;
    letter-spacing: -0.02em;
    background: linear-gradient(90deg, #ffffff 0%, #ffffff 40%, #c084fc 55%, #ec4899 85%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
    text-shadow: 0 0 60px rgba(168, 85, 247, 0.15);
  }

  .hero-gaming__subheadline {
    color: #fff;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.43;
  }

  .hero-gaming__subheadline p {
    margin: 0;
  }

  .hero-gaming__description {
    color: #a4a6ab;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.43;
    margin: 0;
    max-width: 334px;
  }

  .hero-gaming__price {
    color: #fff;
    font-size: 40px;
    font-weight: 700;
    line-height: 1.4;
    margin: 0;
  }

  .hero-gaming__ctas {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
  }

  .hero-gaming__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 24px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.43;
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: transform 200ms cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 200ms ease, background 200ms ease;
  }

  .hero-gaming__cta--primary {
    background: linear-gradient(135deg, #a855f7 0%, #ec4899 100%);
    color: #fff;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-gaming__cta--primary::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 30%, rgba(255, 255, 255, 0.28) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 700ms ease;
  }

  .hero-gaming__cta--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 32px rgba(168, 85, 247, 0.5);
  }

  .hero-gaming__cta--primary:hover::after {
    transform: translateX(100%);
  }

  .hero-gaming__cta--primary:hover .hero-gaming__cta-arrow {
    transform: translateX(4px);
  }

  .hero-gaming__cta-arrow {
    transition: transform 200ms ease;
  }

  .hero-gaming__cta--secondary {
    border: 1px solid rgba(255, 255, 255, 0.4);
    color: #fff;
  }

  .hero-gaming__cta--secondary {
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .hero-gaming__cta--secondary:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: #c084fc;
  }

  .hero-gaming__visual {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 600px;
    margin-left: auto;
    opacity: 0;
    transform: scale(0.96);
    animation: hero-image-in 1000ms cubic-bezier(0.2, 0.8, 0.2, 1) 200ms forwards;
  }

  .hero-gaming__visual img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    animation: hero-float 6s ease-in-out infinite;
  }

  @keyframes hero-rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes hero-image-in {
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes hero-float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-14px) rotate(-1deg); }
  }

  @keyframes hero-pulse {
    0%, 100% { opacity: 0.6; transform: translateY(-50%) scale(1); }
    50% { opacity: 1; transform: translateY(-50%) scale(1.05); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-gaming__copy > *,
    .hero-gaming__visual,
    .hero-gaming__visual img,
    .hero-gaming__glow {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }

  @media (max-width: 900px) {
    .hero-gaming__inner {
      grid-template-columns: 1fr;
      padding: 32px 24px;
      gap: 24px;
      text-align: center;
    }

    .hero-gaming__copy {
      max-width: none;
      align-items: center;
    }

    .hero-gaming__description {
      max-width: none;
    }

    .hero-gaming__headline {
      font-size: 48px;
    }

    .hero-gaming__subheadline {
      font-size: 22px;
    }

    .hero-gaming__price {
      font-size: 32px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Gaming",
  "tag": "section",
  "class": "section-hero-gaming",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "STRETCHSENSE"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "GAMING"
    },
    {
      "type": "richtext",
      "id": "subheadline",
      "label": "Sub-headline",
      "default": "<p>Feel Every Move.</p><p>Own Every Game.</p>"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Built for ultimate VR gaming gloves for immersion, precision, and performance."
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "default": "$495"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image (gloves)",
      "info": "Falls back to bundled default if empty"
    },
    {
      "type": "header",
      "content": "Primary CTA"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Buy Now"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "header",
      "content": "Secondary CTA"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Gaming"
    }
  ]
}
{% endschema %}
