{%- liquid
  assign section_id = section.id
-%}

<section
  id="testimonials-youtube-{{ section_id }}"
  class="testimonials-youtube"
  data-section-id="{{ section_id }}"
>
  <div class="testimonials-youtube__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="testimonials-youtube__heading" data-reveal>{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="testimonials-youtube__grid">
      {%- for block in section.blocks -%}
        <a
          class="testimonials-youtube__card"
          data-reveal
          style="--i: {{ forloop.index0 }}"
          {% if block.settings.youtube_url != blank %}href="{{ block.settings.youtube_url }}" target="_blank" rel="noopener"{% else %}href="#" onclick="return false;" role="article"{% endif %}
          {{ block.shopify_attributes }}
        >
          <p class="testimonials-youtube__quote">"{{ block.settings.quote }}"</p>

          <div class="testimonials-youtube__meta">
            <div class="testimonials-youtube__avatar" aria-hidden="true">
              {%- if block.settings.avatar != blank -%}
                <img
                  src="{{ block.settings.avatar | image_url: width: 88 }}"
                  alt="{{ block.settings.name | escape }}"
                  width="44"
                  height="44"
                  loading="lazy"
                >
              {%- else -%}
                <span class="testimonials-youtube__avatar-fallback">{{ block.settings.name | slice: 0, 1 | upcase }}</span>
              {%- endif -%}
            </div>

            <div class="testimonials-youtube__meta-text">
              <p class="testimonials-youtube__name">{{ block.settings.name }}</p>
              <p class="testimonials-youtube__subs">
                {%- if block.settings.subscribers != blank -%}
                  {{ block.settings.subscribers }} subscribers
                {%- endif -%}
              </p>
            </div>

            {%- if block.settings.youtube_url != blank -%}
              <span class="testimonials-youtube__yt" aria-label="Watch on YouTube">
                <svg viewBox="0 0 24 24" fill="#ff0000" aria-hidden="true">
                  <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
                </svg>
              </span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .testimonials-youtube {
    background: #000;
    font-family: 'Montserrat', system-ui, sans-serif;
  }

  .testimonials-youtube__inner {
    max-width: none;
    margin: 0;
    padding: 40px 80px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    align-items: center;
  }

  @media (max-width: 1100px) {
    .testimonials-youtube__inner {
      padding: 40px 32px;
    }
  }

  .testimonials-youtube__heading {
    color: #d1d5db;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    line-height: 1.3;
    text-align: center;
    margin: 0;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 600ms cubic-bezier(0.2, 0.8, 0.2, 1), transform 600ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .testimonials-youtube__heading.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .testimonials-youtube__grid {
    width: 100%;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .testimonials-youtube__card {
    background: linear-gradient(180deg, #0f0817 0%, #08050f 100%);
    border: 1px solid rgba(168, 85, 247, 0.15);
    border-radius: 14px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 20px;
    text-decoration: none;
    color: inherit;
    min-height: 168px;
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 500ms ease calc(var(--i, 0) * 90ms + 150ms),
      transform 500ms ease calc(var(--i, 0) * 90ms + 150ms),
      border-color 220ms ease,
      box-shadow 220ms ease;
  }

  .testimonials-youtube__card.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .testimonials-youtube__card:hover {
    border-color: rgba(168, 85, 247, 0.45);
    box-shadow: 0 10px 26px rgba(168, 85, 247, 0.18);
  }

  .testimonials-youtube__quote {
    color: #e5e7eb;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.55;
    margin: 0;
  }

  .testimonials-youtube__meta {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .testimonials-youtube__avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    background: rgba(168, 85, 247, 0.2);
    border: 1px solid rgba(168, 85, 247, 0.4);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .testimonials-youtube__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .testimonials-youtube__avatar-fallback {
    color: #fff;
    font-size: 15px;
    font-weight: 700;
  }

  .testimonials-youtube__meta-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    flex: 1;
    min-width: 0;
  }

  .testimonials-youtube__name {
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    margin: 0;
  }

  .testimonials-youtube__subs {
    color: #71717a;
    font-size: 11px;
    font-weight: 500;
    margin: 2px 0 0;
  }

  .testimonials-youtube__yt {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .testimonials-youtube__yt svg {
    width: 22px;
    height: 22px;
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonials-youtube__heading,
    .testimonials-youtube__card {
      animation: none !important;
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }

  @media (max-width: 900px) {
    .testimonials-youtube__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 500px) {
    .testimonials-youtube__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Testimonials (YouTube)",
  "tag": "section",
  "class": "section-testimonials-youtube",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "TRUSTED BY VR CREATORS & GAMERS"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar (creator photo)"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "These gloves are an absolute game changer for VRChat."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Creator name",
          "default": "VRCX"
        },
        {
          "type": "text",
          "id": "subscribers",
          "label": "Subscriber count",
          "default": "110K"
        },
        {
          "type": "url",
          "id": "youtube_url",
          "label": "YouTube channel URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials (YouTube)",
      "blocks": [
        { "type": "testimonial", "settings": { "name": "VRCX",         "quote": "These gloves are an absolute game changer for VRChat.",   "subscribers": "110K" } },
        { "type": "testimonial", "settings": { "name": "ThrillSeeker", "quote": "The most natural hand tracking I've ever used in VR.",       "subscribers": "85K"  } },
        { "type": "testimonial", "settings": { "name": "Immersed Ben", "quote": "Perfect for creators and anyone who wants real immersion.",  "subscribers": "62K"  } },
        { "type": "testimonial", "settings": { "name": "LunaVR",       "quote": "Finally, my avatar hands move like my real hands.",          "subscribers": "48K"  } }
      ]
    }
  ]
}
{% endschema %}
