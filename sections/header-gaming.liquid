{%- liquid
  assign section_id = section.id
-%}

<header
  id="header-gaming-{{ section_id }}"
  class="header-gaming"
  data-section-id="{{ section_id }}"
>
  <div class="header-gaming__inner">
    <a href="{{ routes.root_url }}" class="header-gaming__logo" aria-label="{{ shop.name }}">
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 320 }}"
          alt="{{ shop.name | escape }}"
          width="{{ section.settings.logo.width }}"
          height="{{ section.settings.logo.height }}"
        >
      {%- else -%}
        <img
          src="{{ 'stretchsense-logo-white.png' | asset_url }}"
          alt="{{ shop.name | escape }}"
          width="147"
          height="34"
        >
      {%- endif -%}
    </a>

    <nav class="header-gaming__nav" aria-label="Primary">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link' -%}
          {%- assign is_active = false -%}
          {%- if block.settings.active -%}
            {%- assign is_active = true -%}
          {%- endif -%}

          <a
            href="{{ block.settings.link | default: '#' }}"
            class="header-gaming__link{% if is_active %} header-gaming__link--active{% endif %}"
            {% if is_active %}aria-current="page"{% endif %}
            {{ block.shopify_attributes }}
          >
            <span>{{ block.settings.label }}</span>
            {%- if is_active -%}
              <span class="header-gaming__underline" aria-hidden="true"></span>
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}

      {%- if section.settings.cta_label != blank -%}
        <a
          href="{{ section.settings.cta_link | default: '#' }}"
          class="header-gaming__cta"
        >
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="header-gaming__cart" aria-label="Cart ({{ cart.item_count }})">
        <svg viewBox="0 0 20 20" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M2 2h2.5l2 12h11l2-9H6"/>
          <circle cx="8" cy="17" r="1.25"/>
          <circle cx="16" cy="17" r="1.25"/>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="header-gaming__cart-count">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </nav>
  </div>
</header>

{% stylesheet %}
  .header-gaming {
    background: #000;
    color: #fff;
    font-family: 'Montserrat', system-ui, sans-serif;
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }

  .header-gaming__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 24px;
  }

  .header-gaming__logo {
    display: block;
    flex-shrink: 0;
    line-height: 0;
  }

  .header-gaming__logo img {
    height: 34px;
    width: auto;
    display: block;
  }

  .header-gaming__nav {
    display: flex;
    align-items: center;
    gap: 22px;
  }

  .header-gaming__link {
    color: #fff;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.43;
    text-decoration: none;
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    transition: color 150ms ease;
  }

  .header-gaming__link:hover {
    color: #ff6b1a;
  }

  .header-gaming__link--active {
    color: #ff6b1a;
    font-weight: 600;
  }

  .header-gaming__underline {
    display: block;
    width: 56px;
    height: 2px;
    background: #ff6b1a;
  }

  .header-gaming__cta {
    border: 1px solid #ff6b1a;
    color: #fff;
    background: transparent;
    padding: 8px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.43;
    text-decoration: none;
    transition: background 150ms ease;
  }

  .header-gaming__cta:hover {
    background: rgba(255, 107, 26, 0.15);
  }

  .header-gaming__cart {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    color: #fff;
    text-decoration: none;
  }

  .header-gaming__cart svg {
    width: 20px;
    height: 20px;
    display: block;
  }

  .header-gaming__cart-count {
    position: absolute;
    top: -6px;
    right: -8px;
    background: #ff6b1a;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    min-width: 16px;
    height: 16px;
    border-radius: 8px;
    padding: 0 4px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .header-gaming__inner {
      padding: 12px 16px;
    }

    .header-gaming__nav {
      gap: 14px;
    }

    .header-gaming__link {
      display: none;
    }

    .header-gaming__cta {
      padding: 6px 14px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header Gaming",
  "tag": "section",
  "class": "section-header-gaming",
  "max_blocks": 8,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "White logo on dark header. Falls back to bundled default."
    },
    {
      "type": "header",
      "content": "CTA button (right side)"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Nav link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL"
        },
        {
          "type": "checkbox",
          "id": "active",
          "label": "Show as active (orange + underline)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header Gaming",
      "blocks": [
        { "type": "link", "settings": { "label": "Robotics", "active": false } },
        { "type": "link", "settings": { "label": "XR Training", "active": false } },
        { "type": "link", "settings": { "label": "Gaming", "active": true } },
        { "type": "link", "settings": { "label": "Platform", "active": false } },
        { "type": "link", "settings": { "label": "Technology", "active": false } },
        { "type": "link", "settings": { "label": "Resources", "active": false } }
      ]
    }
  ]
}
{% endschema %}
