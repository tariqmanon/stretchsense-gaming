{%- liquid
  assign section_id = section.id
-%}

<script>
  (() => {
    if (window.__headerGamingScrollInit) return;
    window.__headerGamingScrollInit = true;

    const header = document.querySelector('.header-gaming');
    if (!header) return;

    const threshold = 80;
    const delta = 8;
    let lastY = window.scrollY;
    let ticking = false;

    const update = () => {
      const y = window.scrollY;
      const diff = y - lastY;

      if (y <= threshold) {
        header.classList.remove('header-gaming--hidden');
      } else if (diff > delta) {
        header.classList.add('header-gaming--hidden');
      } else if (diff < -delta) {
        header.classList.remove('header-gaming--hidden');
      }

      lastY = y;
      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  })();
</script>

<header
  id="header-gaming-{{ section_id }}"
  class="header-gaming"
  data-section-id="{{ section_id }}"
>
  <div class="header-gaming__inner">
    {%- liquid
      assign logo_href = section.settings.logo_link | default: routes.root_url
      assign logo_target = ''
      if logo_href contains '://' and logo_href contains 'myshopify' == false
        unless logo_href contains shop.permanent_domain or logo_href contains shop.secure_url
          assign logo_target = 'external'
        endunless
      endif
    -%}
    <a
      href="{{ logo_href }}"
      class="header-gaming__logo"
      aria-label="{{ shop.name }}"
      {% if logo_target == 'external' %}target="_blank" rel="noopener"{% endif %}
    >
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 320 }}"
          alt="{{ shop.name | escape }}"
          width="{{ section.settings.logo.width }}"
          height="{{ section.settings.logo.height }}"
        >
      {%- else -%}
        <img
          src="{{ 'stretchsense-logo-white.png' | asset_url }}"
          alt="{{ shop.name | escape }}"
          width="147"
          height="34"
        >
      {%- endif -%}
    </a>

    <nav class="header-gaming__nav" aria-label="Primary">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link' -%}
          {%- assign is_active = false -%}
          {%- if block.settings.active -%}
            {%- assign is_active = true -%}
          {%- endif -%}

          <a
            href="{{ block.settings.link | default: '#' }}"
            class="header-gaming__link{% if is_active %} header-gaming__link--active{% endif %}"
            {% if is_active %}aria-current="page"{% endif %}
            {{ block.shopify_attributes }}
          >
            <span>{{ block.settings.label }}</span>
            {%- if is_active -%}
              <span class="header-gaming__underline" aria-hidden="true"></span>
            {%- endif -%}
          </a>
        {%- endif -%}
      {%- endfor -%}

      {%- if section.settings.cta_label != blank -%}
        <a
          href="{{ section.settings.cta_link | default: '#' }}"
          class="header-gaming__cta"
        >
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}

      <div class="header-gaming__actions">
        {%- render 'header-actions', section: section, display_style: 'icon' -%}
      </div>
    </nav>
  </div>
</header>

{% stylesheet %}
  .header-gaming {
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #fff;
    font-family: 'Montserrat', system-ui, sans-serif;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transform: translateY(0);
    transition: transform 300ms cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: transform;
  }

  .header-gaming--hidden {
    transform: translateY(-100%);
  }

  body {
    --header-gaming-offset: 64px;
    padding-top: var(--header-gaming-offset);
  }

  .header-gaming__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 24px;
  }

  .header-gaming__logo {
    display: block;
    flex-shrink: 0;
    line-height: 0;
  }

  .header-gaming__logo img {
    height: 34px;
    width: auto;
    display: block;
  }

  .header-gaming__nav {
    display: flex;
    align-items: center;
    gap: 22px;
  }

  .header-gaming__link {
    color: #fff;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.43;
    text-decoration: none;
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    transition: color 150ms ease;
  }

  .header-gaming__link:hover {
    color: #ff6b1a;
  }

  .header-gaming__link--active {
    color: #ff6b1a;
    font-weight: 600;
  }

  .header-gaming__underline {
    display: block;
    width: 56px;
    height: 2px;
    background: #ff6b1a;
  }

  .header-gaming__cta {
    border: 1px solid #ff6b1a;
    color: #fff;
    background: transparent;
    padding: 8px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.43;
    text-decoration: none;
    transition: background 150ms ease;
  }

  .header-gaming__cta:hover {
    background: rgba(255, 107, 26, 0.15);
  }

  /* === Theme header-actions snippet adapted to our dark theme === */
  .header-gaming__actions {
    display: inline-flex;
    align-items: center;
  }

  .header-gaming__actions header-actions {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: #fff;
  }

  /* Hide the account button — not in Figma design */
  .header-gaming__actions .account-button,
  .header-gaming__actions shopify-account {
    display: none !important;
  }

  /* Cart icon trigger button */
  .header-gaming__actions [data-testid='cart-drawer-trigger'],
  .header-gaming__actions .action__cart {
    background: transparent;
    border: none;
    padding: 4px;
    cursor: pointer;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: color 150ms ease;
  }

  .header-gaming__actions [data-testid='cart-drawer-trigger']:hover,
  .header-gaming__actions .action__cart:hover {
    color: #ff6b1a;
  }

  .header-gaming__actions .header-actions__cart-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: inherit;
    --icon-stroke-width: 1.5;
  }

  .header-gaming__actions .header-actions__cart-icon svg {
    width: 24px;
    height: 24px;
    display: block;
    /* clear the donut mask the theme applies for default header */
    mask: none !important;
    -webkit-mask: none !important;
  }

  /* The "Cart" text label — hide, we want icon-only */
  .header-gaming__actions .header-actions__cart-icon > span:not(.svg-wrapper):not(.cart-bubble) {
    display: none;
  }

  /* Cart bubble — orange pill in top-right corner */
  .header-gaming__actions .cart-bubble {
    position: absolute;
    top: -6px;
    right: -8px;
    width: auto;
    min-width: 16px;
    height: 16px;
    aspect-ratio: auto;
    padding: 0 4px;
    border-radius: 999px;
    background: transparent;
  }

  .header-gaming__actions .cart-bubble.visually-hidden {
    display: none;
  }

  .header-gaming__actions .cart-bubble__background {
    background: #ff6b1a;
    border-radius: 999px;
    inset: 0;
  }

  .header-gaming__actions .cart-bubble__text {
    position: relative;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    z-index: 1;
  }

  .header-gaming__actions .cart-bubble__text-count {
    color: #fff;
    font-family: 'Montserrat', system-ui, sans-serif;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .header-gaming__inner {
      padding: 12px 16px;
    }

    .header-gaming__nav {
      gap: 14px;
    }

    .header-gaming__link {
      display: none;
    }

    .header-gaming__cta {
      padding: 6px 14px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header Gaming",
  "tag": "section",
  "class": "section-header-gaming",
  "max_blocks": 8,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "White logo on dark header. Falls back to bundled default."
    },
    {
      "type": "url",
      "id": "logo_link",
      "label": "Logo link",
      "info": "Where the logo navigates when clicked. Leave empty for store home. External URLs open in a new tab."
    },
    {
      "type": "header",
      "content": "CTA button (right side)"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Nav link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL"
        },
        {
          "type": "checkbox",
          "id": "active",
          "label": "Show as active (orange + underline)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header Gaming",
      "blocks": [
        { "type": "link", "settings": { "label": "Robotics", "active": false } },
        { "type": "link", "settings": { "label": "XR Training", "active": false } },
        { "type": "link", "settings": { "label": "Gaming", "active": true } },
        { "type": "link", "settings": { "label": "Platform", "active": false } },
        { "type": "link", "settings": { "label": "Technology", "active": false } },
        { "type": "link", "settings": { "label": "Resources", "active": false } }
      ]
    }
  ]
}
{% endschema %}
