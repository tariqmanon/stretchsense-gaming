{%- liquid
  assign section_id = section.id
-%}
<script>
  (() => {
    if (window.__headerGamingScrollInit) return;
    window.__headerGamingScrollInit = true;

    const header = document.querySelector('.header-gaming');
    if (!header) return;

    const threshold = 80;
    const delta = 8;
    let lastY = window.scrollY;
    let ticking = false;

    const update = () => {
      if (header.classList.contains('header-gaming--menu-open')) {
        header.classList.remove('header-gaming--hidden');
        lastY = window.scrollY;
        ticking = false;
        return;
      }
      const y = window.scrollY;
      const diff = y - lastY;
      if (y <= threshold) {
        header.classList.remove('header-gaming--hidden');
      } else if (diff > delta) {
        header.classList.add('header-gaming--hidden');
      } else if (diff < -delta) {
        header.classList.remove('header-gaming--hidden');
      }
      lastY = y;
      ticking = false;
    };

    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  })();
</script>

<header
  id="header-gaming-{{ section_id }}"
  class="header-gaming"
  data-section-id="{{ section_id }}"
>
  <div class="header-gaming__inner">
    {%- liquid
      assign logo_href = section.settings.logo_link | default: routes.root_url
      assign logo_target = ''
      if logo_href contains '://'
        unless logo_href contains 'myshopify'
          unless logo_href contains shop.permanent_domain
            assign logo_target = 'external'
          endunless
        endunless
      endif
    -%}
    <a
      href="{{ logo_href }}"
      class="header-gaming__logo"
      aria-label="{{ shop.name }}"
      {% if logo_target == 'external' %}target="_blank" rel="noopener"{% endif %}
    >
      {%- if section.settings.logo != blank -%}
        <img
          src="{{ section.settings.logo | image_url: width: 320 }}"
          alt="{{ shop.name | escape }}"
          width="{{ section.settings.logo.width }}"
          height="{{ section.settings.logo.height }}"
        >
      {%- else -%}
        <img
          src="{{ 'stretchsense-logo-white.png' | asset_url }}"
          alt="{{ shop.name | escape }}"
          width="147"
          height="34"
        >
      {%- endif -%}
    </a>

    <button
      type="button"
      class="header-gaming__menu-toggle"
      aria-expanded="false"
      aria-controls="header-gaming-nav-{{ section_id }}"
      aria-label="Toggle menu"
      data-header-menu-toggle
    >
      <span class="header-gaming__menu-icon" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <div
      class="header-gaming__nav-wrapper"
      id="header-gaming-nav-{{ section_id }}"
      data-header-nav-wrapper
    >
      <nav class="header-gaming__nav" aria-label="Primary">
        <div class="header-gaming__nav-links">
          {%- for block in section.blocks -%}
            {%- if block.type == 'link' -%}
              {%- liquid
                assign is_active = false
                if block.settings.active
                  assign is_active = true
                endif

                assign has_submenu = false
                assign submenu_lines = block.settings.submenu_items | newline_to_br | split: '<br />'
                if block.settings.has_submenu and submenu_lines.size > 0
                  assign has_submenu = true
                endif
              -%}
              <div class="header-gaming__nav-item{% if has_submenu %} header-gaming__nav-item--has-submenu{% endif %}" {{ block.shopify_attributes }}>
                <div class="header-gaming__link-row">
                  <a
                    href="{{ block.settings.link | default: '#' }}"
                    class="header-gaming__link{% if is_active %} header-gaming__link--active{% endif %}"
                    {% if is_active %}aria-current="page"{% endif %}
                  >
                    <span>{{ block.settings.label }}</span>
                    {%- if is_active -%}
                      <span class="header-gaming__underline" aria-hidden="true"></span>
                    {%- endif -%}
                  </a>

                  {%- if has_submenu -%}
                    <button
                      type="button"
                      class="header-gaming__submenu-toggle"
                      aria-expanded="false"
                      aria-label="Toggle {{ block.settings.label }} submenu"
                      data-submenu-toggle
                    >
                      <svg class="header-gaming__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9"/>
                      </svg>
                    </button>
                  {%- endif -%}
                </div>

                {%- if has_submenu -%}
                  <div class="header-gaming__submenu" data-submenu>
                    {%- for line in submenu_lines -%}
                      {%- assign trimmed_line = line | strip -%}
                      {%- if trimmed_line != '' -%}
                        {%- assign parts = trimmed_line | split: '|' -%}
                        {%- if parts.size >= 2 -%}
                          <a href="{{ parts[1] | strip | default: '#' }}" class="header-gaming__submenu-link">
                            {{ parts[0] | strip }}
                          </a>
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.cta_label != blank -%}
          <a
            href="{{ section.settings.cta_link | default: '#' }}"
            class="header-gaming__cta"
          >
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}
      </nav>
    </div>

    <div class="header-gaming__actions">
      {%- if localization.available_languages.size > 1 -%}
        <div class="header-gaming__language">
          {%- render 'localization-form',
            show_country: false,
            show_language: true,
            form_id: section.id,
            localization_style: 'dropdown'
          -%}
        </div>
      {%- endif -%}
      {%- render 'header-actions', section: section, display_style: 'icon' -%}
    </div>
  </div>

  <div class="header-gaming__backdrop" data-header-backdrop></div>
</header>

<script>
  (() => {
    const header = document.getElementById('header-gaming-{{ section_id }}');
    if (!header) return;

    const toggleBtn = header.querySelector('[data-header-menu-toggle]');
    const navWrapper = header.querySelector('[data-header-nav-wrapper]');
    const backdrop = header.querySelector('[data-header-backdrop]');

    const closeMenu = () => {
      header.classList.remove('header-gaming--menu-open');
      toggleBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    const openMenu = () => {
      header.classList.add('header-gaming--menu-open');
      header.classList.remove('header-gaming--hidden');
      toggleBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };

    toggleBtn?.addEventListener('click', () => {
      const isOpen = header.classList.contains('header-gaming--menu-open');
      isOpen ? closeMenu() : openMenu();
    });

    backdrop?.addEventListener('click', closeMenu);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth > 900) closeMenu();
    });

    navWrapper?.querySelectorAll('[data-submenu-toggle]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.header-gaming__nav-item');
        if (!item) return;
        const isOpen = item.classList.contains('is-open');

        navWrapper.querySelectorAll('.header-gaming__nav-item.is-open').forEach((openItem) => {
          if (openItem !== item) {
            openItem.classList.remove('is-open');
            openItem.querySelector('[data-submenu-toggle]')?.setAttribute('aria-expanded', 'false');
          }
        });

        item.classList.toggle('is-open', !isOpen);
        btn.setAttribute('aria-expanded', String(!isOpen));
      });
    });

    navWrapper?.querySelectorAll('.header-gaming__link, .header-gaming__submenu-link, .header-gaming__cta').forEach((link) => {
      link.addEventListener('click', () => {
        if (window.innerWidth <= 900) closeMenu();
      });
    });
  })();
</script>

{% stylesheet %}
  .header-gaming {
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #fff;
    font-family: 'Montserrat', system-ui, sans-serif;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    transform: translateY(0);
    transition: transform 300ms cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: transform;
  }

  .header-gaming--hidden {
    transform: translateY(-100%);
  }

  body {
    --header-gaming-offset: 64px;
    padding-top: var(--header-gaming-offset);
  }

  .header-gaming__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    gap: 24px;
  }

  .header-gaming__logo {
    display: block;
    flex-shrink: 0;
    line-height: 0;
  }

  .header-gaming__logo img {
    height: 34px;
    width: auto;
    display: block;
  }

  /* --- Mobile menu toggle button (hidden on desktop) --- */
  .header-gaming__menu-toggle {
    display: none;
    background: transparent;
    border: none;
    padding: 8px;
    margin-left: auto;
    cursor: pointer;
    color: #fff;
  }

  .header-gaming__menu-icon {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 22px;
  }

  .header-gaming__menu-icon span {
    display: block;
    height: 2px;
    width: 100%;
    background: #fff;
    border-radius: 2px;
    transition: transform 200ms ease, opacity 200ms ease;
  }

  .header-gaming--menu-open .header-gaming__menu-icon span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .header-gaming--menu-open .header-gaming__menu-icon span:nth-child(2) {
    opacity: 0;
  }

  .header-gaming--menu-open .header-gaming__menu-icon span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* --- Nav --- */
  .header-gaming__nav-wrapper {
    display: flex;
    flex: 1;
    justify-content: flex-end;
  }

  .header-gaming__nav {
    display: flex;
    align-items: center;
    gap: 22px;
  }

  .header-gaming__nav-links {
    display: flex;
    align-items: center;
    gap: 22px;
  }

  .header-gaming__nav-item {
    position: relative;
  }

  .header-gaming__link-row {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .header-gaming__link {
    color: #fff;
    font-size: 14px;
    font-weight: 500;
    line-height: 1.43;
    text-decoration: none;
    position: relative;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    transition: color 150ms ease;
  }

  .header-gaming__link:hover {
    color: #a855f7;
  }

  .header-gaming__link--active {
    color: #a855f7;
    font-weight: 600;
  }

  .header-gaming__underline {
    display: block;
    width: 56px;
    height: 2px;
    background: #a855f7;
  }

  .header-gaming__submenu-toggle {
    background: transparent;
    border: none;
    padding: 2px;
    color: #a1a1aa;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  .header-gaming__submenu-toggle:hover {
    color: #a855f7;
  }

  .header-gaming__chevron {
    width: 14px;
    height: 14px;
    transition: transform 200ms ease;
  }

  .header-gaming__nav-item.is-open .header-gaming__chevron {
    transform: rotate(180deg);
  }

  /* Desktop dropdown submenu */
  .header-gaming__submenu {
    display: none;
    position: absolute;
    top: calc(100% + 14px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 200px;
    background: #0f0817;
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 10px;
    padding: 8px;
    flex-direction: column;
    gap: 2px;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5);
    z-index: 5;
  }

  .header-gaming__nav-item--has-submenu:hover .header-gaming__submenu,
  .header-gaming__nav-item--has-submenu.is-open .header-gaming__submenu {
    display: flex;
  }

  .header-gaming__submenu-link {
    color: #d1d5db;
    font-size: 13px;
    text-decoration: none;
    padding: 8px 10px;
    border-radius: 6px;
    transition: background 150ms ease, color 150ms ease;
  }

  .header-gaming__submenu-link:hover {
    background: rgba(168, 85, 247, 0.14);
    color: #fff;
  }

  .header-gaming__cta {
    border: 1px solid #a855f7;
    color: #fff;
    background: transparent;
    padding: 8px 20px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.43;
    text-decoration: none;
    transition: background 150ms ease;
    white-space: nowrap;
  }

  .header-gaming__cta:hover {
    background: rgba(168, 85, 247, 0.15);
  }

  /* === Language selector === */
  .header-gaming__language {
    display: inline-flex;
    align-items: center;
    font-family: inherit;
  }

  .header-gaming__language localization-form-component {
    background: transparent;
  }

  .header-gaming__language button,
  .header-gaming__language [role="button"] {
    background: transparent !important;
    border: 1px solid rgba(255, 255, 255, 0.15) !important;
    color: #fff !important;
    font-family: 'Montserrat', system-ui, sans-serif !important;
    font-size: 12px !important;
    font-weight: 600 !important;
    padding: 6px 10px !important;
    border-radius: 6px !important;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: background 150ms ease, border-color 150ms ease;
  }

  .header-gaming__language button:hover,
  .header-gaming__language [role="button"]:hover {
    background: rgba(168, 85, 247, 0.15) !important;
    border-color: #a855f7 !important;
  }

  @media (max-width: 640px) {
    .header-gaming__language button,
    .header-gaming__language [role="button"] {
      font-size: 11px !important;
      padding: 5px 8px !important;
    }
  }

  /* === Theme header-actions snippet adapted to our dark theme === */
  .header-gaming__actions {
    display: inline-flex;
    align-items: center;
  }

  .header-gaming__actions header-actions {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: #fff;
  }

  .header-gaming__actions .account-button {
    background: transparent;
    border: none;
    padding: 4px;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: color 150ms ease;
    cursor: pointer;
    --icon-stroke-width: 1.5;
  }

  .header-gaming__actions .account-button:hover {
    color: #a855f7;
  }

  .header-gaming__actions .account-button shopify-account {
    color: inherit;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .header-gaming__actions .account-button__icon {
    width: 22px;
    height: 22px;
    color: inherit;
    stroke: currentColor;
  }

  .header-gaming__actions .account-button [slot='signed-out-avatar'] {
    display: inline-flex;
    align-items: center;
    color: inherit;
  }

  .header-gaming__actions [data-testid='cart-drawer-trigger'],
  .header-gaming__actions .action__cart {
    background: transparent;
    border: none;
    padding: 4px;
    cursor: pointer;
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: color 150ms ease;
  }

  .header-gaming__actions [data-testid='cart-drawer-trigger']:hover,
  .header-gaming__actions .action__cart:hover {
    color: #a855f7;
  }

  .header-gaming__actions .header-actions__cart-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: inherit;
    --icon-stroke-width: 1.5;
  }

  .header-gaming__actions .header-actions__cart-icon svg {
    width: 24px;
    height: 24px;
    display: block;
    mask: none !important;
    -webkit-mask: none !important;
  }

  .header-gaming__actions .header-actions__cart-icon > span:not(.svg-wrapper):not(.cart-bubble) {
    display: none;
  }

  .header-gaming__actions .cart-bubble {
    position: absolute;
    top: -6px;
    right: -8px;
    width: auto;
    min-width: 16px;
    height: 16px;
    aspect-ratio: auto;
    padding: 0 4px;
    border-radius: 999px;
    background: transparent;
  }

  .header-gaming__actions .cart-bubble.visually-hidden {
    display: none;
  }

  .header-gaming__actions .cart-bubble__background {
    background: #a855f7;
    border-radius: 999px;
    inset: 0;
  }

  .header-gaming__actions .cart-bubble__text {
    position: relative;
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    line-height: 1;
    z-index: 1;
  }

  .header-gaming__actions .cart-bubble__text-count {
    color: #fff;
    font-family: 'Montserrat', system-ui, sans-serif;
    font-weight: 700;
  }

  /* --- Backdrop (mobile only, shown behind open drawer) --- */
  .header-gaming__backdrop {
    display: none;
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.6);
    z-index: -1;
    opacity: 0;
    transition: opacity 200ms ease;
    pointer-events: none;
  }

  /* =========================================================
     MOBILE (<= 900px): hamburger + slide-down drawer
     ========================================================= */
  @media (max-width: 900px) {
    .header-gaming__inner {
      padding: 12px 16px;
    }

    .header-gaming__menu-toggle {
      display: inline-flex;
    }

    .header-gaming__nav-wrapper {
      position: fixed;
      top: 64px;
      left: 0;
      right: 0;
      max-height: 0;
      overflow: hidden;
      background: rgba(0, 0, 0, 0.98);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      transition: max-height 320ms cubic-bezier(0.2, 0.8, 0.2, 1);
      justify-content: flex-start;
    }

    .header-gaming--menu-open .header-gaming__nav-wrapper {
      max-height: calc(100vh - 64px);
      overflow-y: auto;
    }

    .header-gaming--menu-open .header-gaming__backdrop {
      display: block;
      opacity: 1;
      pointer-events: auto;
      z-index: 40;
    }

    .header-gaming__nav {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      padding: 12px 20px 28px;
      gap: 4px;
    }

    .header-gaming__nav-links {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      width: 100%;
    }

    .header-gaming__nav-item {
      width: 100%;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .header-gaming__link-row {
      width: 100%;
      justify-content: space-between;
      padding: 4px 0;
    }

    .header-gaming__link {
      flex-direction: row;
      justify-content: space-between;
      width: 100%;
      padding: 14px 4px;
      gap: 0;
    }

    .header-gaming__underline {
      display: none;
    }

    .header-gaming__submenu-toggle {
      padding: 14px 8px;
    }

    .header-gaming__submenu {
      display: none;
      position: static;
      transform: none;
      width: 100%;
      background: rgba(255, 255, 255, 0.03);
      border: none;
      border-radius: 8px;
      margin: 0 0 8px;
      box-shadow: none;
    }

    .header-gaming__nav-item.is-open .header-gaming__submenu {
      display: flex;
    }

    .header-gaming__submenu-link {
      padding: 12px 14px;
    }

    .header-gaming__cta {
      margin-top: 16px;
      text-align: center;
      width: 100%;
      padding: 12px 20px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header Gaming",
  "tag": "section",
  "class": "section-header-gaming",
  "max_blocks": 8,
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "White logo on dark header. Falls back to bundled default."
    },
    {
      "type": "url",
      "id": "logo_link",
      "label": "Logo link",
      "info": "Where the logo navigates when clicked. Leave empty for store home. External URLs open in a new tab."
    },
    {
      "type": "header",
      "content": "CTA button (right side)"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Nav link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL"
        },
        {
          "type": "checkbox",
          "id": "active",
          "label": "Show as active (purple + underline)",
          "default": false
        },
        {
          "type": "header",
          "content": "Submenu (optional)"
        },
        {
          "type": "checkbox",
          "id": "has_submenu",
          "label": "Enable submenu",
          "default": false
        },
        {
          "type": "textarea",
          "id": "submenu_items",
          "label": "Submenu items",
          "info": "One per line, format: Label | URL",
          "default": "Sublink 1 | #\nSublink 2 | #"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header Gaming",
      "blocks": [
        { "type": "link", "settings": { "label": "Robotics", "active": false } },
        { "type": "link", "settings": { "label": "XR Training", "active": false } },
        { "type": "link", "settings": { "label": "Gaming", "active": true } },
        { "type": "link", "settings": { "label": "Platform", "active": false } },
        { "type": "link", "settings": { "label": "Technology", "active": false } },
        { "type": "link", "settings": { "label": "Resources", "active": false } }
      ]
    }
  ]
}
{% endschema %}
