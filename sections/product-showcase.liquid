{%- liquid
  assign section_id = section.id
  assign product = section.settings.product
  assign has_product = false
  assign can_add_to_cart = false
  assign cta_text = section.settings.cta_label | default: 'Add to Cart'

  if product != blank
    assign has_product = true
    assign variant = product.selected_or_first_available_variant
    if variant.available
      assign can_add_to_cart = true
    else
      assign cta_text = 'Sold Out'
    endif
  endif

  comment
    Resolve title: product takes precedence, else section setting.
  endcomment
  if has_product
    assign display_title = product.title
  else
    assign display_title = section.settings.title
  endif

  comment
    Resolve image: section override > product featured > bundled default.
  endcomment
  if section.settings.image != blank
    assign display_image_source = 'custom'
  elsif has_product and product.featured_image != blank
    assign display_image_source = 'product'
  else
    assign display_image_source = 'default'
  endif

  comment
    Resolve spec bullets:
    1. Product metafield (list type)
    2. Section blocks (manually entered)
  endcomment
  assign specs_list = product.metafields.custom.specs.value
  assign use_metafield_specs = false
  if specs_list != blank and specs_list.size > 0
    assign use_metafield_specs = true
  endif
-%}

<section
  id="product-showcase-{{ section_id }}"
  class="product-showcase"
  data-section-id="{{ section_id }}"
>
  <div class="product-showcase__inner">
    <div class="product-showcase__visual" data-reveal>
      {%- if display_image_source == 'custom' -%}
        <img
          src="{{ section.settings.image | image_url: width: 900 }}"
          srcset="{{ section.settings.image | image_url: width: 500 }} 500w, {{ section.settings.image | image_url: width: 900 }} 900w"
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="{{ section.settings.image.alt | default: display_title | escape }}"
          width="406"
          height="397"
          loading="lazy"
        >
      {%- elsif display_image_source == 'product' -%}
        <img
          src="{{ product.featured_image | image_url: width: 900 }}"
          srcset="{{ product.featured_image | image_url: width: 500 }} 500w, {{ product.featured_image | image_url: width: 900 }} 900w"
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="{{ product.featured_image.alt | default: display_title | escape }}"
          width="406"
          height="397"
          loading="lazy"
        >
      {%- else -%}
        <img
          src="{{ 'product-showcase-gloves.png' | asset_url }}"
          alt="{{ display_title | escape }}"
          width="406"
          height="397"
          loading="lazy"
        >
      {%- endif -%}
    </div>

    <div class="product-showcase__specs" data-reveal>
      {%- if display_title != blank -%}
        {%- if has_product -%}
          <h2 class="product-showcase__title">
            <a href="{{ product.url }}">{{ display_title }}</a>
          </h2>
        {%- else -%}
          <h2 class="product-showcase__title">{{ display_title }}</h2>
        {%- endif -%}
      {%- endif -%}

      <ul class="product-showcase__spec-list">
        {%- if use_metafield_specs -%}
          {%- for spec in specs_list -%}
            <li style="--i: {{ forloop.index0 }}">
              <span class="product-showcase__dot" aria-hidden="true"></span>
              <span>{{ spec }}</span>
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'spec' -%}
              <li {{ block.shopify_attributes }} style="--i: {{ forloop.index0 }}">
                <span class="product-showcase__dot" aria-hidden="true"></span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </ul>

      <p class="product-showcase__price">
        {%- if has_product -%}
          {{ product.price | money }}
        {%- else -%}
          {{ section.settings.price }}
        {%- endif -%}
      </p>

      {%- if has_product -%}
        <product-form-component
          data-section-id="{{ section.id }}"
          data-product-id="{{ product.id }}"
          data-product-url="{{ product.url }}"
          on:submit="/handleSubmit"
        >
          {%- form 'product', product, id: 'product-showcase-form-' | append: section.id, data-type: 'add-to-cart-form' -%}
            <input
              type="hidden"
              name="id"
              ref="variantId"
              value="{{ variant.id }}"
            >
            <add-to-cart-component
              ref="addToCartButtonContainer"
              data-product-variant-media="{{ product.featured_media.preview_image | image_url: width: 100 }}"
            >
              <button
                type="submit"
                name="add"
                ref="addToCartButton"
                on:click="/handleClick"
                class="product-showcase__cta"
                {% unless can_add_to_cart %}disabled{% endunless %}
              >
                <span>{{ cta_text }}</span>
                <span aria-hidden="true">&rarr;</span>
              </button>
            </add-to-cart-component>
          {%- endform -%}
        </product-form-component>
      {%- else -%}
        <a class="product-showcase__cta" href="{{ section.settings.cta_link | default: '#' }}">
          <span>{{ section.settings.cta_label | default: 'Add to Cart' }}</span>
          <span aria-hidden="true">&rarr;</span>
        </a>
      {%- endif -%}

      {%- if section.settings.note != blank -%}
        <p class="product-showcase__note">{{ section.settings.note }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .product-showcase {
    background: #000;
    font-family: 'Montserrat', system-ui, sans-serif;
  }

  .product-showcase__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 32px 64px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
    min-height: 480px;
  }

  .product-showcase__visual {
    width: 100%;
    aspect-ratio: 406 / 397;
    max-width: 480px;
    opacity: 0;
    transform: translateX(-32px);
    transition: opacity 700ms cubic-bezier(0.2, 0.8, 0.2, 1), transform 700ms cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: transform, opacity;
  }

  .product-showcase__visual.is-revealed {
    opacity: 1;
    transform: translateX(0);
  }

  .product-showcase__visual img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    animation: product-float 7s ease-in-out infinite;
  }

  .product-showcase__specs {
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 420px;
    opacity: 0;
    transform: translateX(32px);
    transition: opacity 700ms cubic-bezier(0.2, 0.8, 0.2, 1) 100ms, transform 700ms cubic-bezier(0.2, 0.8, 0.2, 1) 100ms;
  }

  .product-showcase__specs.is-revealed {
    opacity: 1;
    transform: translateX(0);
  }

  .product-showcase__title {
    color: #fff;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.43;
    margin: 0;
  }

  .product-showcase__title a {
    color: inherit;
    text-decoration: none;
    transition: color 200ms ease;
  }

  .product-showcase__title a:hover {
    color: #ff6b1a;
  }

  .product-showcase__spec-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .product-showcase__spec-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #e4e6ea;
    font-size: 14px;
    font-weight: 400;
    line-height: 1.43;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 500ms ease calc(var(--i, 0) * 80ms + 200ms), transform 500ms ease calc(var(--i, 0) * 80ms + 200ms);
  }

  .product-showcase__specs.is-revealed .product-showcase__spec-list li {
    opacity: 1;
    transform: translateY(0);
  }

  .product-showcase__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ff6b1a;
    display: inline-block;
    flex-shrink: 0;
    box-shadow: 0 0 6px rgba(255, 107, 26, 0.6);
  }

  .product-showcase__price {
    color: #fff;
    font-size: 36px;
    font-weight: 700;
    line-height: 1.33;
    margin: 0;
  }

  .product-showcase__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #ff6b1a;
    color: #fff;
    padding: 14px 28px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.43;
    text-decoration: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    width: fit-content;
    position: relative;
    overflow: hidden;
    transition: transform 200ms cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 200ms ease;
  }

  .product-showcase__cta::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(120deg, transparent 30%, rgba(255, 255, 255, 0.25) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 600ms ease;
  }

  .product-showcase__cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(255, 107, 26, 0.4);
  }

  .product-showcase__cta:hover::after {
    transform: translateX(100%);
  }

  .product-showcase__cta:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .product-showcase__note {
    color: #818286;
    font-size: 12px;
    font-weight: 400;
    line-height: 1.33;
    margin: 0;
  }

  @keyframes product-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-showcase__visual img,
    .product-showcase__visual,
    .product-showcase__specs,
    .product-showcase__spec-list li,
    .product-showcase__cta {
      animation: none !important;
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }

  @media (max-width: 900px) {
    .product-showcase__inner {
      grid-template-columns: 1fr;
      padding: 32px 24px;
      gap: 24px;
    }

    .product-showcase__specs {
      max-width: none;
    }

    .product-showcase__title {
      font-size: 22px;
    }

    .product-showcase__price {
      font-size: 28px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Showcase",
  "tag": "section",
  "class": "section-product-showcase",
  "max_blocks": 10,
  "settings": [
    {
      "type": "paragraph",
      "content": "When a product is linked, the section pulls title, image, price, and spec bullets directly from the product. Spec bullets come from the metafield `custom.specs` (list type). Manual blocks below are only used if no product is linked."
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Link the StretchSense Gaming Gloves product. Title, image, price, and Add-to-Cart wire up automatically."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image override (optional)",
      "info": "Use this only if you want to override the product's featured image."
    },
    {
      "type": "header",
      "content": "Static fallbacks (used only when no product is linked)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title (fallback)",
      "default": "StretchSense Gaming Gloves"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price (fallback)",
      "default": "$495"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Add to Cart"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link (fallback)"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Note below CTA",
      "default": "Free shipping worldwide"
    }
  ],
  "blocks": [
    {
      "type": "spec",
      "name": "Spec bullet (fallback)",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Bullet text",
          "default": "Advanced motion tracking"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Showcase",
      "blocks": [
        { "type": "spec", "settings": { "text": "Advanced motion tracking" } },
        { "type": "spec", "settings": { "text": "Haptic feedback" } },
        { "type": "spec", "settings": { "text": "Bluetooth 5.0 + Wi-Fi" } },
        { "type": "spec", "settings": { "text": "Up to 12+ hours battery life" } }
      ]
    }
  ]
}
{% endschema %}
