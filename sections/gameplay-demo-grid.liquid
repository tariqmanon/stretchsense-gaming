{%- liquid
  assign section_id = section.id
-%}

<section
  id="gameplay-demo-grid-{{ section_id }}"
  class="gameplay-grid"
  data-section-id="{{ section_id }}"
>
  <div class="gameplay-grid__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="gameplay-grid__heading" data-reveal>{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="gameplay-grid__items">
      {%- for block in section.blocks -%}
        {%- assign default_image = 'gameplay-demo-1.png' -%}
        {%- if forloop.index == 2 -%}{%- assign default_image = 'gameplay-demo-2.png' -%}{%- endif -%}
        {%- if forloop.index == 3 -%}{%- assign default_image = 'gameplay-demo-3.png' -%}{%- endif -%}
        {%- if forloop.index >= 4 -%}{%- assign default_image = 'gameplay-demo-4.png' -%}{%- endif -%}

        <a
          href="{{ block.settings.video_url | default: '#' }}"
          class="gameplay-grid__card"
          data-reveal
          style="--i: {{ forloop.index0 }}"
          {{ block.shopify_attributes }}
          {% if block.settings.video_url contains 'youtube' or block.settings.video_url contains 'vimeo' %}target="_blank" rel="noopener"{% endif %}
        >
          <div class="gameplay-grid__thumb">
            {%- if block.settings.thumbnail != blank -%}
              <img
                src="{{ block.settings.thumbnail | image_url: width: 420 }}"
                srcset="{{ block.settings.thumbnail | image_url: width: 240 }} 240w, {{ block.settings.thumbnail | image_url: width: 420 }} 420w"
                sizes="(max-width: 768px) 50vw, 25vw"
                alt="{{ block.settings.label | escape }}"
                width="208"
                height="155"
                loading="lazy"
              >
            {%- else -%}
              <img
                src="{{ default_image | asset_url }}"
                alt="{{ block.settings.label | escape }}"
                width="208"
                height="155"
                loading="lazy"
              >
            {%- endif -%}

            <span class="gameplay-grid__play" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle cx="16" cy="16" r="16" fill="rgba(0,0,0,0.55)"/>
                <path d="M13 11l8 5-8 5V11z" fill="#fff"/>
              </svg>
            </span>
          </div>
          <p class="gameplay-grid__label">{{ block.settings.label }}</p>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .gameplay-grid {
    background: #000;
    font-family: 'Montserrat', system-ui, sans-serif;
  }

  .gameplay-grid__inner {
    max-width: none;
    margin: 0;
    padding: 28px 80px 36px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    align-items: center;
  }

  @media (max-width: 1100px) {
    .gameplay-grid__inner {
      padding: 28px 32px 36px;
    }
  }

  .gameplay-grid__heading {
    color: #fff;
    font-size: 24px;
    font-weight: 700;
    line-height: 1.5;
    text-align: center;
    margin: 0;
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 600ms cubic-bezier(0.2, 0.8, 0.2, 1), transform 600ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .gameplay-grid__heading.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .gameplay-grid__items {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    width: 100%;
  }

  .gameplay-grid__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    border: 1px solid rgba(129, 130, 134, 0.38);
    border-radius: 8px;
    text-decoration: none;
    background: #000;
    padding-bottom: 18px;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 600ms cubic-bezier(0.2, 0.8, 0.2, 1) calc(var(--i, 0) * 80ms + 150ms),
      transform 600ms cubic-bezier(0.2, 0.8, 0.2, 1) calc(var(--i, 0) * 80ms + 150ms),
      border-color 250ms ease,
      box-shadow 250ms ease;
  }

  .gameplay-grid__card.is-revealed {
    opacity: 1;
    transform: translateY(0);
  }

  .gameplay-grid__card:hover {
    transform: translateY(-4px);
    border-color: rgba(168, 85, 247, 0.55);
    box-shadow: 0 12px 28px rgba(168, 85, 247, 0.15);
  }

  .gameplay-grid__thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 208 / 155;
    overflow: hidden;
    margin-bottom: 14px;
    border-radius: 7px 7px 0 0;
  }

  .gameplay-grid__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform-origin: center center;
    transition: transform 500ms cubic-bezier(0.2, 0.8, 0.2, 1), filter 300ms ease;
  }

  .gameplay-grid__card:hover .gameplay-grid__thumb img {
    transform: scale(1.03);
    filter: brightness(1.08);
  }

  .gameplay-grid__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(1);
    width: 32px;
    height: 32px;
    display: block;
    transition: transform 250ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .gameplay-grid__card:hover .gameplay-grid__play {
    transform: translate(-50%, -50%) scale(1.15);
  }

  .gameplay-grid__play svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .gameplay-grid__label {
    color: #fff;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.5;
    margin: 0;
    padding: 0 12px;
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .gameplay-grid__heading,
    .gameplay-grid__card,
    .gameplay-grid__thumb img,
    .gameplay-grid__play {
      animation: none !important;
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }

  @media (max-width: 900px) {
    .gameplay-grid__heading {
      font-size: 20px;
    }
  }

  @media (max-width: 768px) {
    .gameplay-grid__inner {
      padding: 24px 16px 32px;
      gap: 20px;
    }

    .gameplay-grid__items {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .gameplay-grid__label {
      font-size: 13px;
      padding: 0 8px;
    }
  }

  @media (max-width: 480px) {
    .gameplay-grid__items {
      gap: 10px;
    }
    .gameplay-grid__label {
      font-size: 12px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Gameplay Demo Grid",
  "tag": "section",
  "class": "section-gameplay-grid",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for Immersion. Designed for Gamers."
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Demo video",
      "settings": [
        {
          "type": "image_picker",
          "id": "thumbnail",
          "label": "Thumbnail image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Gameplay Demo"
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Gameplay Demo Grid",
      "blocks": [
        { "type": "video", "settings": { "label": "Gameplay Demo" } },
        { "type": "video", "settings": { "label": "Gameplay Demo" } },
        { "type": "video", "settings": { "label": "Gameplay Demo" } },
        { "type": "video", "settings": { "label": "Gameplay Demo" } }
      ]
    }
  ]
}
{% endschema %}
