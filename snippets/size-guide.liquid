{%- comment -%}
  Size Guide — renders a "📏 Size Guide" text link that opens a modal with
  the product's size guide image.

  Setup:
    - Product metafield `custom.size_guide_image` (File type) must be set.
    - Include via {% render 'size-guide' %} inside the product template
      (drop a Custom Liquid block between Variant picker and Buy buttons).
{%- endcomment -%}

{%- liquid
  assign p = product
  if p == blank
    assign p = closest.product
  endif
  assign size_guide = p.metafields.custom.size_guide_image.value
-%}

{%- if size_guide != blank -%}
  <div class="size-guide-wrap">
    <button
      type="button"
      class="size-guide-trigger"
      data-size-guide-open
      aria-haspopup="dialog"
    >
      <span aria-hidden="true">📏</span>
      <span>Size Guide</span>
    </button>

    <div
      class="size-guide-modal"
      data-size-guide-modal
      hidden
      role="dialog"
      aria-modal="true"
      aria-label="Size guide"
    >
      <div class="size-guide-modal__backdrop" data-size-guide-close></div>
      <div class="size-guide-modal__panel" role="document">
        <button
          type="button"
          class="size-guide-modal__close"
          data-size-guide-close
          aria-label="Close size guide"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M4 4l12 12M16 4L4 16"/>
          </svg>
        </button>
        <img
          src="{{ size_guide.url }}"
          alt="{{ p.title | escape }} size guide"
          class="size-guide-modal__image"
          loading="lazy"
        >
      </div>
    </div>
  </div>

  <style>
    .size-guide-wrap {
      margin-top: 4px;
      font-family: inherit;
    }

    .size-guide-trigger {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: transparent;
      border: none;
      padding: 6px 0;
      color: inherit;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      text-decoration: underline;
      text-underline-offset: 3px;
      opacity: 0.75;
      transition: opacity 150ms ease;
      font-family: inherit;
      line-height: 1.4;
    }

    .size-guide-trigger:hover,
    .size-guide-trigger:focus-visible {
      opacity: 1;
      outline: none;
    }

    .size-guide-modal[hidden] {
      display: none;
    }

    .size-guide-modal {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .size-guide-modal__backdrop {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.75);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      cursor: pointer;
      animation: sg-fade-in 200ms ease;
    }

    .size-guide-modal__panel {
      position: relative;
      background: #fff;
      border-radius: 12px;
      max-width: min(900px, 90vw);
      max-height: 90vh;
      overflow: auto;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
      animation: sg-scale-in 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .size-guide-modal__close {
      position: absolute;
      top: 12px;
      right: 12px;
      background: rgba(255, 255, 255, 0.95);
      border: 1px solid rgba(0, 0, 0, 0.08);
      border-radius: 50%;
      width: 36px;
      height: 36px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: #000;
      transition: transform 150ms ease, background 150ms ease;
      z-index: 1;
    }

    .size-guide-modal__close:hover {
      transform: scale(1.08);
      background: #fff;
    }

    .size-guide-modal__close:focus-visible {
      outline: 2px solid #ff6b1a;
      outline-offset: 2px;
    }

    .size-guide-modal__image {
      display: block;
      width: 100%;
      height: auto;
      max-width: 100%;
    }

    @keyframes sg-fade-in {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    @keyframes sg-scale-in {
      from { opacity: 0; transform: scale(0.96); }
      to   { opacity: 1; transform: scale(1); }
    }

    @media (max-width: 640px) {
      .size-guide-modal {
        padding: 12px;
      }
      .size-guide-modal__panel {
        max-height: 88vh;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .size-guide-modal__backdrop,
      .size-guide-modal__panel {
        animation: none;
      }
    }
  </style>

  <script>
    (function () {
      var wrap = document.currentScript.closest('.size-guide-wrap');
      if (!wrap || wrap.__sizeGuideInit) return;
      wrap.__sizeGuideInit = true;

      var modal = wrap.querySelector('[data-size-guide-modal]');
      var openBtn = wrap.querySelector('[data-size-guide-open]');
      var closers = wrap.querySelectorAll('[data-size-guide-close]');
      var body = document.body;

      function open() {
        modal.hidden = false;
        body.style.overflow = 'hidden';
        var closeBtn = modal.querySelector('.size-guide-modal__close');
        if (closeBtn) closeBtn.focus();
      }

      function close() {
        modal.hidden = true;
        body.style.overflow = '';
        openBtn.focus();
      }

      openBtn.addEventListener('click', open);
      closers.forEach(function (el) {
        el.addEventListener('click', close);
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && !modal.hidden) close();
      });
    })();
  </script>
{%- endif -%}
