{%- comment -%}
  Truncated product description with "Read more" toggle.

  Usage inside a Custom Liquid block on any product-context section:
    {% render 'product-description-truncate' %}
    {% render 'product-description-truncate', words: 100 %}
    {% render 'product-description-truncate', words: 200, expand: 'See more', collapse: 'Hide' %}
{%- endcomment -%}

{%- liquid
  assign p = closest.product
  if p == blank
    assign p = product
  endif

  assign word_limit = words | default: 150
  assign expand_label = expand | default: 'Read more'
  assign collapse_label = collapse | default: 'Read less'

  assign full_html = p.description
  assign plain_text = full_html | strip_html | strip_newlines | strip
  assign word_count = plain_text | split: ' ' | size
  assign needs_truncate = false
  if word_count > word_limit
    assign needs_truncate = true
  endif
  assign short_text = plain_text | truncatewords: word_limit, '...'
  assign unique_id = p.id | append: '-' | append: word_limit
-%}

{%- if plain_text != blank -%}
  <div class="pd-truncate" data-pd-truncate="{{ unique_id }}">
    {%- if needs_truncate -%}
      <div class="pd-truncate__short" data-pd-short>
        <p>{{ short_text }}</p>
      </div>
      <div class="pd-truncate__full" data-pd-full hidden>
        {{ full_html }}
      </div>
      <button
        type="button"
        class="pd-truncate__toggle"
        data-pd-toggle
        data-expand="{{ expand_label | escape }}"
        data-collapse="{{ collapse_label | escape }}"
        aria-expanded="false"
      >
        <span data-pd-label>{{ expand_label }}</span>
        <svg class="pd-truncate__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </button>
    {%- else -%}
      <div class="pd-truncate__full">
        {{ full_html }}
      </div>
    {%- endif -%}
  </div>

  <style>
    .pd-truncate {
      font-family: inherit;
      line-height: 1.6;
      color: inherit;
    }

    .pd-truncate__short p,
    .pd-truncate__full p {
      margin: 0 0 12px;
    }

    .pd-truncate__short p:last-child,
    .pd-truncate__full p:last-child {
      margin-bottom: 0;
    }

    .pd-truncate__full[hidden] {
      display: none;
    }

    .pd-truncate__toggle {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      margin-top: 12px;
      padding: 0;
      background: transparent;
      border: none;
      cursor: pointer;
      color: #a855f7;
      font-family: inherit;
      font-size: 14px;
      font-weight: 600;
      letter-spacing: 0.02em;
      transition: color 150ms ease;
    }

    .pd-truncate__toggle:hover,
    .pd-truncate__toggle:focus-visible {
      color: #c084fc;
      outline: none;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .pd-truncate__chevron {
      width: 16px;
      height: 16px;
      transition: transform 250ms cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .pd-truncate__toggle[aria-expanded="true"] .pd-truncate__chevron {
      transform: rotate(180deg);
    }
  </style>

  <script>
    (function () {
      var wrap = document.querySelector('[data-pd-truncate="{{ unique_id }}"]');
      if (!wrap || wrap.__pdTruncateInit) return;
      wrap.__pdTruncateInit = true;

      var toggle = wrap.querySelector('[data-pd-toggle]');
      var shortEl = wrap.querySelector('[data-pd-short]');
      var fullEl = wrap.querySelector('[data-pd-full]');
      var label = wrap.querySelector('[data-pd-label]');
      if (!toggle || !fullEl) return;

      toggle.addEventListener('click', function () {
        var expanded = toggle.getAttribute('aria-expanded') === 'true';
        if (expanded) {
          fullEl.hidden = true;
          if (shortEl) shortEl.hidden = false;
          toggle.setAttribute('aria-expanded', 'false');
          if (label) label.textContent = toggle.getAttribute('data-expand');
        } else {
          fullEl.hidden = false;
          if (shortEl) shortEl.hidden = true;
          toggle.setAttribute('aria-expanded', 'true');
          if (label) label.textContent = toggle.getAttribute('data-collapse');
        }
      });
    })();
  </script>
{%- endif -%}
