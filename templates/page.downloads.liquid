{% comment %}
  Downloads page — public.
  Lists every active product that has a "custom.sdk_download_url" metafield set.
  Add a new product to the page by setting its SDK URL metafield in admin —
  no code change needed.
{% endcomment %}

<section class="downloads-gaming">
  <div class="downloads-gaming__inner">
    <header class="downloads-gaming__header">
      <h1 class="downloads-gaming__title">XR Game App Downloads</h1>
      <p class="downloads-gaming__lede">
        Download the latest StretchSense software for your glove. Use the
        download that matches the product you purchased.
      </p>
    </header>

    {%- assign sdk_count = 0 -%}
    <div class="downloads-gaming__grid">
      {%- for product in collections.all.products -%}
        {%- assign sdk_url = product.metafields.custom.sdk_download_url -%}
        {%- if sdk_url == blank -%}{%- continue -%}{%- endif -%}
        {%- assign sdk_count = sdk_count | plus: 1 -%}

        <article class="downloads-card">
          {%- if product.featured_image -%}
            <img
              src="{{ product.featured_image | image_url: width: 240 }}"
              alt="{{ product.title | escape }}"
              class="downloads-card__image"
              width="120"
              height="120"
              loading="lazy"
            >
          {%- endif -%}

          <div class="downloads-card__body">
            <h2 class="downloads-card__title">{{ product.title }}</h2>
            {%- if product.metafields.custom.sdk_version != blank -%}
              <p class="downloads-card__version">Version {{ product.metafields.custom.sdk_version }}</p>
            {%- endif -%}
            <p class="downloads-card__lede">
              SDK installer for {{ product.title }} customers.
            </p>

            <a
              href="{{ sdk_url }}"
              class="downloads-card__btn"
              download
              rel="noopener"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Download SDK
            </a>
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- if sdk_count == 0 -%}
      <div class="downloads-gaming__empty">
        <h2>No downloads available yet</h2>
        <p>SDKs will appear here once they're attached to products.</p>
      </div>
    {%- endif -%}

    <p class="downloads-gaming__support">
      Need help? <a href="/pages/contact">Contact support</a> or join our community on Discord.
    </p>
  </div>
</section>

<style>
  .downloads-gaming {
    background: #0a0a0a;
    color: #fff;
    font-family: 'Montserrat', system-ui, sans-serif;
    min-height: 70vh;
    padding: 80px 24px 120px;
  }

  .downloads-gaming__inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .downloads-gaming__header {
    margin-bottom: 48px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .downloads-gaming__title {
    font-size: clamp(32px, 4vw, 48px);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }

  .downloads-gaming__lede {
    color: rgba(255, 255, 255, 0.7);
    font-size: 16px;
    line-height: 1.6;
    max-width: 640px;
    margin: 0;
  }

  .downloads-gaming__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
  }

  .downloads-card {
    background: linear-gradient(180deg, rgba(255, 107, 26, 0.06) 0%, rgba(255, 255, 255, 0.02) 100%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 28px;
    display: flex;
    gap: 20px;
    align-items: flex-start;
    transition: border-color 150ms ease, transform 150ms ease;
  }

  .downloads-card:hover {
    border-color: rgba(255, 107, 26, 0.3);
    transform: translateY(-2px);
  }

  .downloads-card__image {
    width: 100px;
    height: 100px;
    border-radius: 12px;
    object-fit: cover;
    flex-shrink: 0;
    background: rgba(255, 255, 255, 0.04);
  }

  .downloads-card__body {
    flex: 1;
    min-width: 0;
  }

  .downloads-card__title {
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 4px;
    line-height: 1.2;
    color: #fff;
  }

  .downloads-card__version {
    color: #ff6b1a;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 12px;
  }

  .downloads-card__lede {
    color: rgba(255, 255, 255, 0.65);
    font-size: 13px;
    line-height: 1.6;
    margin: 0 0 18px;
  }

  .downloads-card__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    background: #ff6b1a;
    color: #fff;
    border: 1px solid #ff6b1a;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background 150ms ease, transform 150ms ease;
  }

  .downloads-card__btn:hover {
    background: #ff8540;
    border-color: #ff8540;
    transform: translateY(-1px);
  }

  .downloads-gaming__empty {
    text-align: center;
    padding: 60px 20px;
    border: 1px dashed rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.02);
  }

  .downloads-gaming__empty h2 {
    font-size: 22px;
    margin: 0 0 12px;
  }

  .downloads-gaming__empty p {
    color: rgba(255, 255, 255, 0.65);
    line-height: 1.6;
    margin: 0;
  }

  .downloads-gaming__support {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.5);
    font-size: 13px;
    text-align: center;
  }

  .downloads-gaming__support a {
    color: #ff6b1a;
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .downloads-gaming {
      padding: 56px 16px 80px;
    }

    .downloads-card {
      padding: 20px;
      flex-direction: column;
      align-items: stretch;
      text-align: left;
    }

    .downloads-card__image {
      width: 72px;
      height: 72px;
    }

    .downloads-card__btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
