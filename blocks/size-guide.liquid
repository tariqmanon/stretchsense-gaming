{%- liquid
  assign p = closest.product
  if p == blank
    assign p = product
  endif
  assign size_guide = p.metafields.custom.size_guide_image.value
  assign button_label = block.settings.button_label | default: 'Size Guide'
  assign modal_title = block.settings.modal_title | default: 'Size Guide'

  assign size_guide_src = ''
  assign size_guide_alt = p.title | append: ' size guide'
  if size_guide != blank
    assign size_guide_src = size_guide | image_url: width: 1200
    if size_guide_src == blank and size_guide.url != blank
      assign size_guide_src = size_guide.url
    endif
    if size_guide.alt != blank
      assign size_guide_alt = size_guide.alt
    endif
  endif
-%}

<div class="size-guide-block" {{ block.shopify_attributes }}>
  <button
    type="button"
    class="size-guide-block__trigger"
    data-size-guide-open
    aria-haspopup="dialog"
  >
    <svg class="size-guide-block__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <rect x="2" y="8" width="20" height="8" rx="1"/>
      <path d="M6 8v3M10 8v4M14 8v3M18 8v4"/>
    </svg>
    <span>{{ button_label }}</span>
  </button>

  <div
    class="size-guide-block__modal"
    data-size-guide-modal
    hidden
    role="dialog"
    aria-modal="true"
    aria-labelledby="size-guide-title-{{ block.id }}"
  >
    <div class="size-guide-block__backdrop" data-size-guide-close></div>
    <div class="size-guide-block__panel" role="document">
      <div class="size-guide-block__header">
        <h2 class="size-guide-block__title" id="size-guide-title-{{ block.id }}">
          {{ modal_title }}
        </h2>
        <button
          type="button"
          class="size-guide-block__close"
          data-size-guide-close
          aria-label="Close size guide"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <path d="M4 4l12 12M16 4L4 16"/>
          </svg>
        </button>
      </div>

      <div class="size-guide-block__body">
        {%- if size_guide_src != blank -%}
          <img
            src="{{ size_guide_src }}"
            alt="{{ size_guide_alt | escape }}"
            class="size-guide-block__image"
            loading="lazy"
          >
        {%- else -%}
          <div class="size-guide-block__empty">
            <svg class="size-guide-block__empty-icon" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="8" y="12" width="48" height="40" rx="3"/>
              <path d="M8 24h48M24 12v40"/>
            </svg>
            <p class="size-guide-block__empty-text">
              Add a size guide image to the product metafield: <code>custom.size_guide_image</code>
            </p>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  .size-guide-block {
    margin: 8px 0;
    font-family: inherit;
  }

  .size-guide-block__trigger {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: linear-gradient(135deg, #a855f7 0%, #ec4899 100%);
    border: none;
    padding: 12px 24px;
    color: #fff;
    font-family: inherit;
    font-size: 14px;
    font-weight: 600;
    line-height: 1.4;
    border-radius: 10px;
    cursor: pointer;
    transition: transform 200ms cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 200ms ease, filter 200ms ease;
    box-shadow: 0 4px 14px rgba(168, 85, 247, 0.35);
  }

  .size-guide-block__trigger:hover,
  .size-guide-block__trigger:focus-visible {
    transform: translateY(-1px);
    box-shadow: 0 8px 22px rgba(168, 85, 247, 0.5);
    filter: brightness(1.06);
    outline: none;
  }

  .size-guide-block__icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .size-guide-block__modal[hidden] {
    display: none;
  }

  .size-guide-block__modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .size-guide-block__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    cursor: pointer;
    animation: sgb-fade-in 200ms ease;
  }

  .size-guide-block__panel {
    position: relative;
    background: #fff;
    border-radius: 12px;
    max-width: min(900px, 90vw);
    max-height: 90vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
    animation: sgb-scale-in 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .size-guide-block__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 24px 16px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .size-guide-block__title {
    margin: 0;
    font-size: 20px;
    font-weight: 700;
    color: #111;
  }

  .size-guide-block__close {
    background: transparent;
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #111;
    transition: background 150ms ease;
  }

  .size-guide-block__close:hover {
    background: rgba(0, 0, 0, 0.06);
  }

  .size-guide-block__close:focus-visible {
    outline: 2px solid #a855f7;
    outline-offset: 2px;
  }

  .size-guide-block__body {
    flex: 1;
    overflow: auto;
  }

  .size-guide-block__image {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
  }

  .size-guide-block__empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 32px;
    color: #6b7280;
  }

  .size-guide-block__empty-icon {
    width: 64px;
    height: 64px;
    color: #d1d5db;
    margin-bottom: 20px;
  }

  .size-guide-block__empty-text {
    font-size: 14px;
    line-height: 1.5;
    margin: 0;
    max-width: 420px;
  }

  .size-guide-block__empty-text code {
    background: rgba(168, 85, 247, 0.1);
    color: #a855f7;
    padding: 2px 6px;
    border-radius: 4px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 13px;
  }

  @keyframes sgb-fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  @keyframes sgb-scale-in {
    from { opacity: 0; transform: scale(0.96); }
    to   { opacity: 1; transform: scale(1); }
  }

  @media (max-width: 640px) {
    .size-guide-block__modal {
      padding: 12px;
    }
    .size-guide-block__panel {
      max-height: 88vh;
    }
    .size-guide-block__header {
      padding: 16px 20px 12px;
    }
    .size-guide-block__title {
      font-size: 18px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .size-guide-block__backdrop,
    .size-guide-block__panel {
      animation: none;
    }
  }
</style>

<script>
  (function () {
    var wrap = document.currentScript.previousElementSibling;
    while (wrap && !wrap.classList.contains('size-guide-block')) {
      wrap = wrap.previousElementSibling;
    }
    if (!wrap || wrap.__sizeGuideBlockInit) return;
    wrap.__sizeGuideBlockInit = true;

    var modal = wrap.querySelector('[data-size-guide-modal]');
    var openBtn = wrap.querySelector('[data-size-guide-open]');
    var closers = wrap.querySelectorAll('[data-size-guide-close]');
    var body = document.body;

    function open() {
      modal.hidden = false;
      body.style.overflow = 'hidden';
      var closeBtn = modal.querySelector('.size-guide-block__close');
      if (closeBtn) closeBtn.focus();
    }

    function close() {
      modal.hidden = true;
      body.style.overflow = '';
      openBtn.focus();
    }

    openBtn.addEventListener('click', open);
    closers.forEach(function (el) {
      el.addEventListener('click', close);
    });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.hidden) close();
    });
  })();
</script>

{% schema %}
{
  "name": "Size Guide",
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Size Guide"
    },
    {
      "type": "text",
      "id": "modal_title",
      "label": "Modal title",
      "default": "Size Guide"
    },
    {
      "type": "paragraph",
      "content": "Reads from the product's `custom.size_guide_image` metafield (File type). Set per product in Products → [product] → Metafields. Works on product pages AND inside a Featured Product section on the homepage."
    }
  ],
  "presets": [
    {
      "name": "Size Guide",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
