{%- liquid
  assign p = closest.product
  if p == blank
    assign p = block.settings.product
  endif

  assign full_html = p.description
  assign plain_text = full_html | strip_html | strip_newlines | strip
  assign word_limit = block.settings.word_limit | default: 150
  assign word_count = plain_text | split: ' ' | size
  assign needs_truncate = false
  if word_count > word_limit
    assign needs_truncate = true
  endif
  assign short_text = plain_text | truncatewords: word_limit, '...'
-%}

{%- if plain_text != blank -%}
  <div class="pde" data-pde {{ block.shopify_attributes }}>
    {%- if needs_truncate -%}
      <div class="pde__short" data-pde-short>
        <p>{{ short_text }}</p>
      </div>
      <div class="pde__full" data-pde-full hidden>
        {{ full_html }}
      </div>
      <button
        type="button"
        class="pde__toggle"
        data-pde-toggle
        aria-expanded="false"
      >
        <span data-pde-toggle-label>{{ block.settings.expand_label | default: 'Read more' }}</span>
        <svg class="pde__chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </button>
    {%- else -%}
      <div class="pde__full">
        {{ full_html }}
      </div>
    {%- endif -%}
  </div>
{%- endif -%}

<style>
  .pde {
    font-family: inherit;
    line-height: 1.6;
    color: inherit;
  }

  .pde__short p,
  .pde__full p {
    margin: 0 0 12px;
  }

  .pde__short p:last-child,
  .pde__full p:last-child {
    margin-bottom: 0;
  }

  .pde__full[hidden] {
    display: none;
  }

  .pde__toggle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    color: #a855f7;
    font-family: inherit;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    transition: color 150ms ease;
  }

  .pde__toggle:hover,
  .pde__toggle:focus-visible {
    color: #c084fc;
    outline: none;
  }

  .pde__chevron {
    width: 16px;
    height: 16px;
    transition: transform 250ms cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .pde__toggle[aria-expanded="true"] .pde__chevron {
    transform: rotate(180deg);
  }

  .pde__toggle:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>

<script>
  (function () {
    var script = document.currentScript;
    var root = script.previousElementSibling;
    while (root && !(root.classList && root.classList.contains('pde'))) {
      root = root.previousElementSibling;
    }
    if (!root || root.__pdeInit) return;
    root.__pdeInit = true;

    var shortEl = root.querySelector('[data-pde-short]');
    var fullEl = root.querySelector('[data-pde-full]');
    var toggle = root.querySelector('[data-pde-toggle]');
    var label = root.querySelector('[data-pde-toggle-label]');
    if (!toggle || !fullEl) return;

    var expandLabel = toggle.getAttribute('data-expand-label') || '{{ block.settings.expand_label | default: "Read more" | escape }}';
    var collapseLabel = toggle.getAttribute('data-collapse-label') || '{{ block.settings.collapse_label | default: "Read less" | escape }}';

    toggle.addEventListener('click', function () {
      var expanded = toggle.getAttribute('aria-expanded') === 'true';
      if (expanded) {
        fullEl.hidden = true;
        if (shortEl) shortEl.hidden = false;
        toggle.setAttribute('aria-expanded', 'false');
        if (label) label.textContent = expandLabel;
      } else {
        fullEl.hidden = false;
        if (shortEl) shortEl.hidden = true;
        toggle.setAttribute('aria-expanded', 'true');
        if (label) label.textContent = collapseLabel;
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Product description (expandable)",
  "settings": [
    {
      "type": "range",
      "id": "word_limit",
      "label": "Word limit (before Read More)",
      "min": 20,
      "max": 500,
      "step": 10,
      "default": 150,
      "info": "Only shows short version if the description is longer than this."
    },
    {
      "type": "text",
      "id": "expand_label",
      "label": "Expand button label",
      "default": "Read more"
    },
    {
      "type": "text",
      "id": "collapse_label",
      "label": "Collapse button label",
      "default": "Read less"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product (fallback if no product context)",
      "info": "Only needed when this block is placed outside a product section."
    }
  ],
  "presets": [
    {
      "name": "Product description (expandable)",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
